From 8600de1abd05d23e4aa22c4d24be970aa3e5d605 Mon Sep 17 00:00:00 2001
From: Nikolay Amiantov <ab@fmap.me>
Date: Sun, 31 May 2026 16:44:21 +0700
Subject: [PATCH] Add Sony a7R VI (ILCE-7RM6) camera support

Adds the camera definition for the Sony a7R VI, enabling decoding of its
uncompressed, lossless-compressed (LJPEG, compression 7) and lossy
"Compressed HQ" (LLVC v3, compression 32766 / arw6) ARW files.

Color matrices are taken from the upstream ILCE-7RM5 (a7R V) entry as a
provisional value (the bodies share a sensor generation); replace with
measured ILCE-7RM6 values when available. They affect only color
rendering, not raw mosaic decoding. Black/white levels, crop, active area
and white balance are read from the ARW metadata.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 rawler/data/cameras/sony/a7rm6.toml | 14 ++++++++++++++
 1 file changed, 14 insertions(+)
 create mode 100644 rawler/data/cameras/sony/a7rm6.toml

diff --git a/rawler/data/cameras/sony/a7rm6.toml b/rawler/data/cameras/sony/a7rm6.toml
new file mode 100644
index 0000000..0bd2a2d
--- /dev/null
+++ b/rawler/data/cameras/sony/a7rm6.toml
@@ -0,0 +1,14 @@
+make = "SONY"
+model = "ILCE-7RM6"
+clean_make = "Sony"
+clean_model = "ILCE-7RM6"
+color_pattern = "RGGB"
+bps = 8
+
+# Provisional color matrices copied from the upstream ILCE-7RM5 (a7R V) entry;
+# replace with measured ILCE-7RM6 values when available. They affect only color
+# rendering, not raw mosaic decoding. Black/white levels, crop, active area and
+# white balance are read from the ARW.
+[cameras.color_matrix]
+A = [0.9185, -0.4857, 0.0505, -0.3651, 1.1061, 0.2982, -0.0161, 0.0698, 0.6769]
+D65 = [0.82, -0.2976, -0.0719, -0.4296, 1.2053, 0.2532, -0.0429, 0.1282, 0.5774]
--
2.53.0
