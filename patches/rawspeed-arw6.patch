+void ArwDecoder::DecodeARW6(const TiffIFD* raw) {
+  uint32_t width = raw->getEntry(TiffTag::IMAGEWIDTH)->getU32();
+  uint32_t height = raw->getEntry(TiffTag::IMAGELENGTH)->getU32();
+
+  // Sony stores the compressed bit depth in the (otherwise-unused for raw)
+  // DefaultCropOrigin tag here; it selects the de-linearization curve. Only a
+  // compressed bit depth of 12 (a7R V / a1) has a known curve.
+  int compBd = 12;
+  if (const TiffEntry* bd = raw->getEntryRecursive(TiffTag::DEFAULTCROPORIGIN))
+    compBd = static_cast<int>(bd->getU32(0));
+
+  const TiffEntry* offsets = raw->getEntry(TiffTag::STRIPOFFSETS);
+  const TiffEntry* counts = raw->getEntry(TiffTag::STRIPBYTECOUNTS);
+  if (offsets->count != 1 || counts->count != 1)
+    ThrowRDE("ARW6: expected a single strip");
+
+  if (width == 0 || height == 0 || width % 2 != 0 || height % 2 != 0 ||
+      width > 11000 || height > 7000)
+    ThrowRDE("Unexpected image dimensions found: (%u; %u)", width, height);
+
+  uint32_t off = offsets->getU32();
+  uint32_t len = counts->getU32();
+  if (!mFile.isValid(off))
+    ThrowRDE("Data offset after EOF, file probably truncated");
+  if (!mFile.isValid(off, len))
+    len = mFile.getSize() - off;
+
+  mRaw->dim = iPoint2D(width, height);
+
+  ByteStream input(DataBuffer(mFile.getSubView(off, len), Endianness::little));
+
+  Arw6Decompressor a(mRaw, input, compBd);
+  mRaw->createData();
+  a.decompress();
+
+  // The output is already linearized through the codec curve, so the black/white
+  // points are in the curve's output scale, not the ARW SR2 metadata scale (the
+  // pre-codec 14-bit domain). Using the SR2 black (512) leaves a pedestal the
+  // white-balance gains turn into a magenta cast. Remember both so
+  // decodeMetaDataInternal can restore them after setMetaData / GetWB overwrite
+  // them from the camera database / SONY tags.
+  if (uint16_t white = Arw6Decompressor::whiteLevel(compBd)) {
+    mRaw->whitePoint = white;
+    mArw6WhiteLevel = white;
+  }
+  if (uint16_t black = Arw6Decompressor::blackLevel(compBd))
+    mArw6BlackLevel = black;
+}
+
 void ArwDecoder::ParseA100WB() const {
   if (!mRootIFD->hasEntryRecursive(TiffTag::DNGPRIVATEDATA))
     return;
@@ -522,6 +577,24 @@ void ArwDecoder::decodeMetaDataInternal(const CameraMetaData* meta) {
     mRaw->setError(e.what());
     // We caught an exception reading WB, just ignore it
   }
+
+  // ARW6 output is linearized through the codec curve; its white level is the
+  // curve-scale saturation point, not the (differently-scaled) SONYWHITELEVEL
+  // tag GetWB() just read. Apply last so it wins.
+  if (mArw6WhiteLevel)
+    mRaw->whitePoint = mArw6WhiteLevel;
+
+  // Likewise the black pedestal is 1024 in the curve scale, not the SR2
+  // SONYBLACKLEVEL (512) GetWB() read into blackLevelSeparate. Leaving 512 here
+  // produces a magenta cast once the white-balance gains are applied.
+  if (mArw6BlackLevel) {
+    mRaw->blackLevel = mArw6BlackLevel;
+    mRaw->blackLevelSeparate =
+        Array2DRef(mRaw->blackLevelSeparateStorage.data(), 2, 2);
+    auto blackLevelSeparate1D = *mRaw->blackLevelSeparate->getAsArray1DRef();
+    for (int i = 0; i < 4; ++i)
+      blackLevelSeparate1D(i) = mArw6BlackLevel;
+  }
 }
 
 void ArwDecoder::SonyDecrypt(Array1DRef<const uint8_t> ibuf,
@@ -644,7 +717,12 @@ void ArwDecoder::GetWB() const {
         blackLevelSeparate1D(i) = bl->getU16(i) >> mShiftDownScaleForExif;
     }
 
-    if (encryptedIFD.hasEntry(TiffTag::SONYWHITELEVEL)) {
+    // The SONYWHITELEVEL tag is below the true sensor saturation on some bodies
+    // (e.g. the a7R VI: 15360 vs the 16383 the 14-bit data actually reaches),
+    // clipping real highlights. For those, keep the white level from the camera
+    // database (cameras.xml Sensor) instead of the tag, matching Adobe.
+    if (encryptedIFD.hasEntry(TiffTag::SONYWHITELEVEL) &&
+        mRootIFD->getID().model != "ILCE-7RM6") {
       const TiffEntry* wl = encryptedIFD.getEntry(TiffTag::SONYWHITELEVEL);
       if (wl->count != 1 && wl->count != 3)
         ThrowRDE("White Level has %u entries instead of 1 or 3", wl->count);
