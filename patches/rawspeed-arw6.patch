+using std::int64_t;
+
+// ---------------------------------------------------------------------------
+// Bitstream reader (entropy.rs / reader.rs)
+//
+// MSB-first over the byte buffer. This is a thin adapter over the shared
+// rawspeed BitStreamerMSB: it already reads MSB-first, zero-fills past the end
+// of the buffer (variableLengthLoadNaiveViaMemcpy) and provides byteAlign().
+// The only thing the codec needs on top is an end-of-stream query so the one
+// unbounded construct -- the adaptive-k zero-run -- terminates instead of
+// consuming the zero-filled tail forever.
+// ---------------------------------------------------------------------------
+class Reader {
+  BitStreamerMSB bs;
+  int len; // length of the real (non-zero-fill) input, in bytes
+
+  static Array1DRef<const std::byte> asBytes(const uint8_t* p, size_t n) {
+    return {reinterpret_cast<const std::byte*>(p), implicit_cast<int>(n)};
+  }
+
+  // Total number of bits consumed from the stream so far.
+  inline int64_t consumedBits() const {
+    return static_cast<int64_t>(bs.getInputPosition()) * 8 - bs.getFillLevel();
+  }
+
+public:
+  Reader(const uint8_t* buf, size_t n)
+      : bs(asBytes(buf, n)), len(implicit_cast<int>(n)) {}
+
+  // Read a single bit MSB-first; past end of buffer yields 0 (zero-fill).
+  inline uint32_t rd1() { return bs.getBits(1); }
+
+  // Read n bits MSB-first as an unsigned value (n in 1..32; n == 0 yields 0).
+  inline uint64_t rdn(uint32_t n) {
+    return n != 0 ? bs.getBits(static_cast<int>(n)) : 0;
+  }
+
+  // Count the run of 0 bits up to the next 1 bit (consuming the 1).
+  // Returns nullopt if the stream ends before a 1 bit is found.
+  inline std::optional<int64_t> readZeros() {
+    int64_t cnt = 0;
+    while (true) {
+      if (consumedBits() >= static_cast<int64_t>(len) * 8)
+        return std::nullopt;
+      if (bs.getBits(1) == 1)
+        return cnt;
+      ++cnt;
+    }
+  }
+
+  // Discard bits up to the next whole-byte boundary.
+  inline void alignByte() { bs.byteAlign(); }
+};
+
+// ---------------------------------------------------------------------------
+// Entropy decode (entropy.rs)
+// ---------------------------------------------------------------------------
+
+// Mid-rise dequantizer: ((2*mag+1) << (q-1)) - (mag & 1), clamped to i32 max.
+inline int64_t dequant(int64_t mag, int64_t q) {
+  if (mag <= 0 || q <= 0)
+    return mag;
+  int64_t r = ((2 * mag + 1) << (q - 1)) - (mag & 1);
+  return r > 0x7fffffff ? 0x7fffffff : r;
+}
+
+// Adaptively update the magnitude-bit count k (FUN_141c84b90).
+int64_t updateK(Reader& r, int64_t k) {
+  if (r.rd1() == 0)
+    return k;
+  if (r.rd1() == 0) {
+    // increase: k += 1 + run(0s). EOF before the terminating 1 -> k unchanged.
+    std::optional<int64_t> z = r.readZeros();
+    return z ? k + 1 + *z : k;
+  }
+  // decrease: drop k by 1 per 0-bit until a 1-bit, bounded by k reaching 0.
+  if (k <= 0)
+    return 0;
+  k -= 1;
+  while (k >= 1) {
+    if (r.rd1() == 1)
+      return k;
+    k -= 1;
+  }
+  return k;
+}
+
+inline uint32_t bitLength(int64_t x) {
+  uint32_t c = 0;
+  while (x > 0) {
+    x >>= 1;
+    ++c;
+  }
+  return c;
+}
+
+// Read a capped unary prefix used for zero-run lengths.
+int64_t readUnaryCapped(Reader& r, int64_t remaining) {
+  if (remaining < 2)
+    return 0;
+  int64_t cap = static_cast<int64_t>(bitLength(remaining - 1));
+  int64_t cnt = 0;
+  while (cnt < cap) {
+    if (r.rd1() == 1)
+      return cnt;
+    ++cnt;
+  }
+  return cnt;
+}
+
+// Decode one 4-coefficient group into out[base..base+4]; return the new k.
+int64_t decodeGroup(Reader& r, int64_t k, int64_t q, bool notLast,
+                    std::vector<int64_t>& out, size_t base) {
+  int64_t m0;
+  int64_t m1;
+  int64_t m2;
+  int64_t m3;
+  if (k <= 0) {
+    m0 = m1 = m2 = m3 = 0;
+  } else if (k < 8) {
+    uint64_t v = r.rdn(static_cast<uint32_t>(k * 4));
+    uint64_t m = (1ULL << k) - 1;
+    m0 = static_cast<int64_t>((v >> (3 * k)) & m);
+    m1 = static_cast<int64_t>((v >> (2 * k)) & m);
+    m2 = static_cast<int64_t>((v >> k) & m);
+    m3 = static_cast<int64_t>(v & m);
+  } else {
+    m0 = static_cast<int64_t>(r.rdn(static_cast<uint32_t>(k)));
+    m1 = static_cast<int64_t>(r.rdn(static_cast<uint32_t>(k)));
+    m2 = static_cast<int64_t>(r.rdn(static_cast<uint32_t>(k)));
+    m3 = static_cast<int64_t>(r.rdn(static_cast<uint32_t>(k)));
+  }
+  int64_t v0 = dequant(m0, q);
+  int64_t v1 = dequant(m1, q);
+  int64_t v2 = dequant(m2, q);
+  int64_t v3 = dequant(m3, q);
+  bool nz0 = m0 > 0;
+  bool nz1 = m1 > 0;
+  bool nz2 = m2 > 0;
+  bool nz3 = m3 > 0;
+  int64_t newK = notLast ? updateK(r, k) : k;
+  uint32_t nsign = static_cast<uint32_t>(nz0) + static_cast<uint32_t>(nz1) +
+                   static_cast<uint32_t>(nz2) + static_cast<uint32_t>(nz3);
+  uint64_t sb = nsign > 0 ? r.rdn(nsign) : 0;
+  uint32_t idx = 0;
+  if (nz0) {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v0 = -v0;
+    ++idx;
+  }
+  if (nz1) {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v1 = -v1;
+    ++idx;
+  }
+  if (nz2) {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v2 = -v2;
+    ++idx;
+  }
+  if (nz3) {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v3 = -v3;
+  }
+  out[base] = v0;
+  out[base + 1] = v1;
+  out[base + 2] = v2;
+  out[base + 3] = v3;
+  return newK;
+}
+
+// Decode a full detail line into out[0..4*groups]; out is fully overwritten.
+void decodeLineDetail(Reader& r, size_t groups, int64_t q,
+                      std::vector<int64_t>& out) {
+  for (size_t i = 0; i < 4 * groups; ++i)
+    out[i] = 0;
+  int64_t k = updateK(r, 0);
+  size_t g = 0;
+  while (g < groups) {
+    if (k == 0) {
+      int64_t rem = static_cast<int64_t>(groups - g);
+      if (rem == 1) {
+        g += 1;
+        continue;
+      }
+      int64_t e = readUnaryCapped(r, rem);
+      int64_t run = static_cast<int64_t>(1) << e;
+      if (run < rem) {
+        if (e > 0)
+          run += static_cast<int64_t>(r.rdn(static_cast<uint32_t>(e))) &
+                 ((static_cast<int64_t>(1) << e) - 1);
+        if (run < 0 || rem < run)
+          break; // inconsistent zero-run length: only on corrupt input
+        g += static_cast<size_t>(run);
+        std::optional<int64_t> z = r.readZeros();
+        if (!z)
+          break;
+        k += 1 + *z;
+        if (k >= 0x14)
+          break;
+      } else {
+        break;
+      }
+    } else {
+      k = decodeGroup(r, k, q, g < groups - 1, out, 4 * g);
+      g += 1;
+    }
+  }
+}
+
+// Wrap to signed 16-bit (the binary stores intermediate coefficients as i16).
+inline int64_t i16wrap(int64_t v) {
+  v &= 0xffff;
+  return v >= 0x8000 ? v - 0x10000 : v;
+}
+
+// Horizontal cumulative-sum prediction for the LL band (FUN_141c85bd0),
+// performed with int16 wraparound. line[0] is unchanged.
+void predictHorizontal(int64_t* line, size_t n) {
+  int64_t acc = i16wrap(line[0] * 2);
+  for (size_t i = 1; i < n; ++i) {
+    acc = i16wrap(line[i] * 2 + acc);
+    line[i] = acc >> 1;
+  }
+}
+
+// ---------------------------------------------------------------------------
+// 2D plane of i64 coefficients/samples (row-major)
+// ---------------------------------------------------------------------------
+struct Plane {
+  size_t w = 0;
+  size_t h = 0;
+  std::vector<int64_t> data;
+
+  Plane() = default;
+  Plane(size_t w_, size_t h_) : w(w_), h(h_), data(w_ * h_, 0) {}
+
+  inline int64_t at(size_t r, size_t c) const { return data[r * w + c]; }
+  inline int64_t& at(size_t r, size_t c) { return data[r * w + c]; }
+};
+
+// ---------------------------------------------------------------------------
+// Inverse wavelet transform (idwt.rs)
+// ---------------------------------------------------------------------------
+
+// Standard inverse 5/3 lifting along axis 0 (rows): coarse at even outputs.
+Plane idwt53(const Plane& low, const Plane& high) {
+  size_t w = low.w;
+  size_t nl = low.h;
+  size_t nh = high.h;
+  size_t n = nl + nh;
+  size_t ne = (n + 1) / 2;
+  Plane x(w, n);
+  for (size_t nn = 0; nn < std::min(nl, ne); ++nn) {
+    for (size_t c = 0; c < w; ++c) {
+      int64_t dm1 = (nn > 0 && nn <= nh) ? high.at(nn - 1, c)
+                    : (nh > 0)           ? high.at(0, c)
+                                         : 0;
+      int64_t d0 = (nn < nh)   ? high.at(nn, c)
+                   : (nh > 0)  ? high.at(nh - 1, c)
+                               : 0;
+      x.at(2 * nn, c) = low.at(nn, c) - ((dm1 + d0 + 2) >> 2);
+    }
+  }
+  for (size_t nn = 0; nn < std::min(nh, n / 2); ++nn) {
+    for (size_t c = 0; c < w; ++c) {
+      int64_t a = x.at(2 * nn, c);
+      int64_t b = (2 * nn + 2 < n) ? x.at(2 * nn + 2, c) : a;
+      x.at(2 * nn + 1, c) = high.at(nn, c) + ((a + b) >> 1);
+    }
+  }
+  return x;
+}
+
+// Inverse 5/3 with flipped polyphase: detail at even outputs, coarse at odd.
+// Matches the binary's vertical lift when the detail-row count is odd.
+Plane idwt53Flip(const Plane& low, const Plane& high) {
+  size_t w = low.w;
+  size_t nl = low.h;
+  size_t nh = high.h;
+  size_t n = nl + nh;
+  Plane lo = low;
+  Plane hi = high;
+  for (size_t nn = 0; nn < nl; ++nn) {
+    for (size_t c = 0; c < w; ++c) {
+      int64_t h0 = (nn < nh) ? hi.at(nn, c) : hi.at(nh - 1, c);
+      int64_t h1 = (nn + 1 < nh) ? hi.at(nn + 1, c) : hi.at(nh - 1, c);
+      lo.at(nn, c) -= (h0 + h1 + 2) >> 2;
+    }
+  }
+  for (size_t nn = 0; nn < nh; ++nn) {
+    for (size_t c = 0; c < w; ++c) {
+      int64_t l0 = (nn >= 1) ? lo.at(nn - 1, c) : lo.at(0, c);
+      int64_t l1 = (nn < nl) ? lo.at(nn, c) : lo.at(nl - 1, c);
+      hi.at(nn, c) += (l0 + l1) >> 1;
+    }
+  }
+  Plane x(w, n);
+  for (size_t nn = 0; nn < nh; ++nn) {
+    if (2 * nn < n)
+      for (size_t c = 0; c < w; ++c)
+        x.at(2 * nn, c) = hi.at(nn, c);
+  }
+  for (size_t nn = 0; nn < nl; ++nn) {
+    if (2 * nn + 1 < n)
+      for (size_t c = 0; c < w; ++c)
+        x.at(2 * nn + 1, c) = lo.at(nn, c);
+  }
+  return x;
+}
+
+// Vertical inverse 5/3: phase chosen by detail-row-count parity (from header
+// geometry, not hardcoded): odd -> flipped polyphase, even -> standard.
+Plane vidwt(const Plane& low, const Plane& high) {
+  return (high.h & 1) == 1 ? idwt53Flip(low, high) : idwt53(low, high);
+}
+
+Plane transpose(const Plane& p) {
+  Plane t(p.h, p.w); // new dims: w'=p.h, h'=p.w
+  for (size_t r = 0; r < p.h; ++r)
+    for (size_t c = 0; c < p.w; ++c)
+      t.at(c, r) = p.at(r, c);
+  return t;
+}
+
+Plane crop(const Plane& p, size_t h, size_t w) {
+  Plane o(w, h);
+  for (size_t r = 0; r < h; ++r)
+    std::copy_n(&p.data[r * p.w], w, &o.data[r * w]);
+  return o;
+}
+
+// One level of 2D inverse 5/3: vertical pass per column-pair, then horizontal.
+// lh/hl/hh are the three detail orientations.
+Plane idwt2d(const Plane& ll, const Plane& lh, const Plane& hl,
+             const Plane& hh) {
+  Plane left = vidwt(ll, lh);
+  Plane right = vidwt(hl, hh);
+  size_t nr = std::min(left.h, right.h);
+  size_t nc = std::min(left.w, right.w);
+  Plane lt = transpose(crop(left, nr, nc));
+  Plane rt = transpose(crop(right, nr, nc));
+  // Horizontal pass: inverse 5/3 along the (transposed) rows, then transpose.
+  return transpose(idwt53(lt, rt));
+}
+
+// Fused vertical IDWT + horizontal upsample combining comp A (V-low) and comp B
+// (V-high) into the luma plane (H x 2W). Port of FUN_141c8a050. Top boundary
+// reflects (line[-1].hi = B[0]); the final output row reflects the bottom.
+Plane streamLuma(const Plane& a, const Plane& b) {
+  size_t h = a.h;
+  size_t w = a.w;
+  Plane lo(w, h);
+  Plane hi(w, h);
+  Plane luma(2 * w, h);
+  for (size_t r = 0; r < h; ++r) {
+    for (size_t n = 0; n < w; ++n)
+      hi.at(r, n) = b.at(r, n);
+    for (size_t n = 0; n + 1 < w; ++n) {
+      int64_t ph0 = (r >= 1) ? hi.at(r - 1, n) : b.at(r, n);
+      int64_t ph1 = (r >= 1) ? hi.at(r - 1, n + 1) : b.at(r, n + 1);
+      int64_t s = b.at(r, n) + b.at(r, n + 1) + ph0 + ph1;
+      lo.at(r, n) = i16wrap((2 * a.at(r, n) - (s >> 2)) >> 1);
+    }
+    int64_t phl = (r >= 1) ? hi.at(r - 1, w - 1) : b.at(r, w - 1);
+    int64_t s = 2 * (b.at(r, w - 1) + phl);
+    lo.at(r, w - 1) = i16wrap((2 * a.at(r, w - 1) - (s >> 2)) >> 1);
+  }
+  for (size_t r = 1; r < h; ++r) {
+    luma.at(r - 1, 0) =
+        i16wrap((((lo.at(r, 0) + lo.at(r - 1, 0)) * 2) >> 2) + hi.at(r - 1, 0));
+    luma.at(r - 1, 1) = lo.at(r - 1, 0);
+    for (size_t i = 1; i < w; ++i) {
+      int64_t ev = i16wrap(((lo.at(r, i - 1) + lo.at(r, i) + lo.at(r - 1, i - 1) +
+                             lo.at(r - 1, i)) >>
+                            2) +
+                           hi.at(r - 1, i));
+      luma.at(r - 1, 2 * i) = ev;
+      luma.at(r - 1, 2 * i + 1) = lo.at(r - 1, i);
+    }
+  }
+  // Last output row: bottom boundary reflects (line[H] = line[H-1] -> rbB=rbA).
+  size_t r = h - 1;
+  luma.at(r, 0) = i16wrap(((lo.at(r, 0) * 2) >> 2) + hi.at(r, 0));
+  luma.at(r, 1) = lo.at(r, 0);
+  for (size_t i = 1; i < w; ++i) {
+    int64_t ev =
+        i16wrap(((2 * (lo.at(r, i - 1) + lo.at(r, i))) >> 2) + hi.at(r, i));
+    luma.at(r, 2 * i) = ev;
+    luma.at(r, 2 * i + 1) = lo.at(r, i);
+  }
+  return luma;
+}
+
+// ---------------------------------------------------------------------------
+// Plane header parsing and band geometry (header.rs)
+// ---------------------------------------------------------------------------
+
+// Row window of one subband orientation: rows [top, bot) with phase rowbase.
+struct Geom {
+  int64_t top;
+  int64_t bot;
+  int64_t rowbase;
+};
+
+// Geometry of one band (1 orientation for LL / comp B, 3 for detail levels).
+struct BandGeom {
+  size_t width = 0;
+  int64_t stride = 1;
+  std::vector<Geom> geoms;
+  bool cumsum = false;
+};
+
+struct Geometry {
+  BandGeom ll;
+  BandGeom b;
+  std::vector<BandGeom> detail; // indexed by vertical level v; valid for 2..=j
+};
+
+struct Record {
+  size_t count;
+  std::vector<int64_t> ents;
+};
+
+inline int64_t u24be(const uint8_t* p, size_t o) {
+  return (static_cast<int64_t>(p[o]) << 16) |
+         (static_cast<int64_t>(p[o + 1]) << 8) | static_cast<int64_t>(p[o + 2]);
+}
+
+// Parse the plane header: the five level totals and the per-level record table.
+void parseHeader(const uint8_t* plane, std::vector<int64_t>& totals,
+                 std::vector<Record>& recs) {
+  const uint8_t* p = plane + 0x10;
+  static constexpr std::array<size_t, 5> kTotOff = {0, 3, 6, 9, 12};
+  totals.clear();
+  for (size_t o : kTotOff)
+    totals.push_back(u24be(p, o) << 4);
+  recs.clear();
+  size_t pos = 0x20;
+  static constexpr std::array<size_t, 5> kOff1 = {1, 4, 7, 10, 13};
+  static constexpr std::array<size_t, 4> kOff2 = {0x11, 0x14, 0x17, 0x1a};
+  for (int i = 0; i < 5; ++i) {
+    size_t count = p[pos] & 0xf;
+    Record rec;
+    rec.count = count;
+    for (size_t j = 0; j < std::min<size_t>(count, 5); ++j)
+      rec.ents.push_back(u24be(p, pos + kOff1[j]) << 4);
+    size_t adv = 0x10;
+    if (count >= 5) {
+      for (size_t j = 0; j < count - 5; ++j)
+        rec.ents.push_back(u24be(p, pos + kOff2[j]) << 4);
+      adv = 0x20;
+    }
+    recs.push_back(std::move(rec));
+    pos += adv;
+  }
+}
+
+// Byte offset (in plane bytes) where the band bitstream begins, i.e. where
+// bandOffset 0 (LL comp0's 16-byte header) sits: 0x10 (plane sub-header) + 0x20
+// (the level-totals block) + the record-table strides (0x10 per record, 0x20
+// when the count nibble >= 5). Mirrors FUN_141c87b30.
+//
+// (The earlier ports used a fixed 672 = this base + the first LL band's 544-byte
+// header+table size, which shifted every bandOffset a constant 544 bytes past
+// its true header.)
+size_t bitstreamBase(const uint8_t* plane) {
+  const uint8_t* p = plane + 0x10;
+  size_t pos = 0x20;
+  for (int i = 0; i < 5; ++i) {
+    size_t count = p[pos] & 0xf;
+    pos += (count >= 5) ? 0x20 : 0x10;
+  }
+  return 0x10 + pos;
+}
+
+// Byte offset of band (region, comp) within the plane entropy buffer.
+size_t bandOffset(const std::vector<int64_t>& totals,
+                  const std::vector<Record>& recs, size_t region, size_t comp) {
+  int64_t base = 0;
+  for (size_t i = 0; i < region; ++i)
+    base += totals[i];
+  for (size_t c = 0; c < comp; ++c)
+    base += recs[region].ents[c];
+  return static_cast<size_t>(base);
+}
+
+// Header region index for a detail band at vertical level v.
+inline size_t detailRegion(size_t v, size_t j) { return j - v + 1; }
+
+// Derive all band geometry from the plane dimensions and level count j.
+Geometry deriveGeom(size_t pw, size_t ph, size_t j) {
+  int64_t pwi = static_cast<int64_t>(pw);
+  std::vector<int64_t> splitLo(j + 1, 0);
+  std::vector<int64_t> splitHi(j + 1, 0);
+  int64_t cur = static_cast<int64_t>(ph);
+  for (size_t v = 1; v <= j; ++v) {
+    splitLo[v] = (cur + 1) / 2;
+    splitHi[v] = cur / 2;
+    cur = (cur + 1) / 2;
+  }
+  std::vector<int64_t> top0(j + 1, 0);
+  std::vector<int64_t> top1(j + 1, 0);
+  top0[1] = 2 * static_cast<int64_t>(j) + 2;
+  for (size_t v = 2; v <= j; ++v)
+    top0[v] = (top0[v - 1] + 1) / 2;
+  if (j >= 2)
+    top1[2] = top0[1] / 2;
+  for (size_t v = 3; v <= j; ++v)
+    top1[v] = top1[v - 1] / 2;
+  int64_t rbb = static_cast<int64_t>(1) << (static_cast<int64_t>(j) - 2);
+  auto rb0 = [&](size_t v) {
+    return std::max<int64_t>(1, rbb >> (static_cast<int64_t>(v) - 1));
+  };
+  auto rb1 = [&](size_t v) { return rbb >> (static_cast<int64_t>(v) - 1); };
+
+  Geometry geo;
+  geo.detail.assign(j + 1, BandGeom{});
+  for (size_t v = 1; v <= j; ++v) {
+    size_t wd = static_cast<size_t>(pwi >> v);
+    int64_t st = static_cast<int64_t>(1)
+                 << (static_cast<int64_t>(j) - static_cast<int64_t>(v));
+    int64_t lo = splitLo[v];
+    int64_t hi = splitHi[v];
+    if (v == 1) {
+      geo.b.width = wd;
+      geo.b.stride = st;
+      geo.b.geoms = {Geom{top0[1], top0[1] + hi, rb0(1)}};
+      geo.b.cumsum = false;
+    } else {
+      BandGeom bg;
+      bg.width = wd;
+      bg.stride = st;
+      bg.cumsum = false;
+      bg.geoms = {Geom{top0[v], top0[v] + hi, rb0(v)},
+                  Geom{top1[v], top1[v] + lo, rb1(v)},
+                  Geom{top1[v], top1[v] + lo, rb1(v)}};
+      geo.detail[v] = std::move(bg);
+    }
+  }
+  int64_t hiJ = splitHi[j];
+  geo.ll.width = static_cast<size_t>(pwi >> j);
+  geo.ll.stride = 1;
+  geo.ll.cumsum = true;
+  geo.ll.geoms = {Geom{top0[j], top0[j] + hiJ, rb0(j)}};
+  return geo;
+}
+
+// Parse a band's 16-byte header at buf[off] (off = bandOffset), the on-disk
+// structure Adobe parses in FUN_141c8b310 and validates per band in
+// FUN_141c86340 (whose failure aborts the decode). Returns the entropy-slice
+// offset and the per-orientation quantizers, read MSB-first (the codec's
+// 64-bit-BE bit order is identical to plain MSB-first over bytes):
+//
+//   16b A | 24b sizeB | 4b magic1(=4) | 4b magic2(=0) | 2b mode | 6b _ |
+//   16b N | 8b (=0x10) | 8b (=0) | 40b _
+//
+// size = (A + 1) * 16 is the total header+table byte size (A satisfies
+// A == ceil((mode + 4) * N / 32)), so the entropy slices begin at off + size.
+// mode is the orientation count (1 for LL & comp B, 3 for detail = HL/LH/HH);
+// each slice entry is bit-packed [16b length][mode*4b q] and q is constant per
+// band, so entry-0's q is read. Read order q[0]=HL, q[1]=LH, q[2]=HH. This
+// supersedes the earlier 7-byte-record prefix/quantizer heuristic.
+std::pair<size_t, std::vector<int64_t>>
+bandHeader(const uint8_t* buf, size_t buflen, size_t off) {
+  size_t avail = off < buflen ? buflen - off : 0;
+  Reader r(buf + std::min(off, buflen), avail);
+  auto a = static_cast<int64_t>(r.rdn(16));
+  r.rdn(24); // sizeB (unused)
+  auto m1 = static_cast<uint32_t>(r.rdn(4));
+  auto m2 = static_cast<uint32_t>(r.rdn(4));
+  auto mode = static_cast<size_t>(r.rdn(2));
+  r.rdn(6);
+  auto n = static_cast<int64_t>(r.rdn(16));
+  auto b9 = static_cast<uint32_t>(r.rdn(8));
+  auto b10 = static_cast<uint32_t>(r.rdn(8));
+  r.rdn(32);
+  r.rdn(8); // 40b reserved (split to stay within a 32-bit read)
+  if (!(m1 == 4 && m2 == 0 && b9 == 0x10 && b10 == 0 &&
+        a == (((static_cast<int64_t>(mode) + 4) * n * 4 + 0x7f) >> 7)))
+    ThrowRDE("ARW6: unexpected LLVC band header @%zu (A=%lld mode=%zu N=%lld "
+             "magic=%u/%u)",
+             off, static_cast<long long>(a), mode, static_cast<long long>(n), m1,
+             m2);
+  r.rdn(16); // entry-0 slice length (unused; entropy is self-delimiting)
+  std::vector<int64_t> q;
+  q.reserve(mode);
+  for (size_t i = 0; i < mode; ++i)
+    q.push_back(static_cast<int64_t>(r.rdn(4)));
+  return {off + (static_cast<size_t>(a) + 1) * 16, q};
+}
+
+// ---------------------------------------------------------------------------
+// Band decode + plane reconstruction (mod.rs)
+// ---------------------------------------------------------------------------
+
+// Decode one band into its orientation planes (1 for LL / comp B, 3 for detail).
+std::vector<Plane> decodeBandContig(const uint8_t* buf, size_t buflen,
+                                    size_t regionOff, size_t width,
+                                    int64_t stride,
+                                    const std::vector<int64_t>& qOrients,
+                                    const std::vector<Geom>& geoms,
+                                    bool cumsum) {
+  size_t groups = roundUpDivision(width, 4);
+  size_t no = geoms.size();
+  std::vector<std::vector<int64_t>> orientData(no);
+  std::vector<size_t> orientH(no, 0);
+  std::vector<int64_t> out(4 * groups, 0);
+  size_t off = std::min(regionOff, buflen);
+  Reader r(buf + off, buflen - off);
+  int64_t row = 0;
+  int64_t maxr = 0;
+  for (const Geom& g : geoms)
+    maxr = std::max(maxr, (g.bot - g.rowbase) / stride + 3);
+  while (row < maxr) {
+    std::vector<int64_t> ns(no);
+    int64_t total = 0;
+    for (size_t o = 0; o < no; ++o) {
+      const Geom& g = geoms[o];
+      int64_t n = std::max<int64_t>(
+          0, std::min(g.bot, g.rowbase + row * stride + stride) -
+                 std::max(g.top, g.rowbase + row * stride));
+      ns[o] = n;
+      total += n;
+    }
+    if (total == 0) {
+      bool allDone = true;
+      for (const Geom& g : geoms)
+        if (g.rowbase + row * stride < g.bot)
+          allDone = false;
+      if (allDone)
+        break;
+      row += 1;
+      continue;
+    }
+    r.alignByte();
+    for (size_t o = 0; o < no; ++o) {
+      for (int64_t i = 0; i < ns[o]; ++i) {
+        decodeLineDetail(r, groups, qOrients[o], out);
+        size_t start = orientData[o].size();
+        orientData[o].insert(orientData[o].end(), out.begin(),
+                             out.begin() + width);
+        if (cumsum)
+          predictHorizontal(orientData[o].data() + start, width);
+        orientH[o] += 1;
+      }
+    }
+    row += 1;
+  }
+  std::vector<Plane> planes;
+  planes.reserve(no);
+  for (size_t o = 0; o < no; ++o) {
+    Plane p;
+    p.w = width;
+    p.h = orientH[o];
+    p.data = std::move(orientData[o]);
+    planes.push_back(std::move(p));
+  }
+  return planes;
+}
+
+// Reconstruct the four wavelet components (A, C, D, B) of one plane.
+void reconstructPlane(const uint8_t* plane, size_t planeLen, size_t pw,
+                      size_t ph, Plane& a, Plane& c, Plane& d, Plane& bband) {
+  if (planeLen < 0x20 + 5 * 0x20)
+    ThrowRDE("ARW6: plane header truncated");
+  std::vector<int64_t> totals;
+  std::vector<Record> recs;
+  parseHeader(plane, totals, recs);
+  size_t j = totals.size() - 1;
+  Geometry geo = deriveGeom(pw, ph, j);
+  // The band bitstream begins at the RE-derived base (not the old fixed 672);
+  // each band starts with its 16-byte header, giving the entropy offset + q.
+  size_t base = bitstreamBase(plane);
+  if (planeLen < base)
+    ThrowRDE("ARW6: plane too short for entropy data");
+  const uint8_t* buf = plane + base;
+  size_t buflen = planeLen - base;
+
+  std::array<Plane, 3> comps;
+  for (size_t comp = 0; comp < 3; ++comp) {
+    const BandGeom& gll = geo.ll;
+    size_t bo = bandOffset(totals, recs, 0, comp);
+    auto [ent, q] = bandHeader(buf, buflen, bo);
+    Plane img = std::move(decodeBandContig(buf, buflen, ent, gll.width,
+                                           gll.stride, q, gll.geoms,
+                                           gll.cumsum)[0]);
+    for (size_t v = j; v >= 2; --v) {
+      size_t region = detailRegion(v, j);
+      if (comp >= recs[region].count)
+        break;
+      const BandGeom& g = geo.detail[v];
+      size_t bo2 = bandOffset(totals, recs, region, comp);
+      // Entropy offset + per-orientation q come from the band's 16-byte header.
+      auto [ent2, q2] = bandHeader(buf, buflen, bo2);
+      std::vector<Plane> dd = decodeBandContig(buf, buflen, ent2, g.width,
+                                               g.stride, q2, g.geoms, g.cumsum);
+      // Orientation mapping: ll, lh=dd[1], hl=dd[0], hh=dd[2].
+      img = idwt2d(img, dd[1], dd[0], dd[2]);
+    }
+    comps[comp] = std::move(img);
+  }
+
+  // comp B (region 4): single full-res highpass band (q from header).
+  const BandGeom& gb = geo.b;
+  size_t bo = bandOffset(totals, recs, 4, 0);
+  auto [entb, qb] = bandHeader(buf, buflen, bo);
+  bband = std::move(decodeBandContig(buf, buflen, entb, gb.width, gb.stride, qb,
+                                     gb.geoms, gb.cumsum)[0]);
+  a = std::move(comps[0]);
+  c = std::move(comps[1]);
+  d = std::move(comps[2]);
+}
+
+// Assemble one quadrant's CFA mosaic (2H x 2W, RGGB) from the components.
+Plane assembleQuadrant(const Plane& a, const Plane& c, const Plane& d,
+                       const Plane& b) {
+  size_t h = std::min(a.h, b.h);
+  size_t w = a.w;
+  Plane acrop = crop(a, h, w);
+  Plane bcrop = crop(b, h, w);
+  Plane luma = streamLuma(acrop, bcrop); // h x 2w greens
+  Plane quad(2 * w, 2 * h);
+  for (size_t i = 0; i < h; ++i) {
+    for (size_t jx = 0; jx < w; ++jx) {
+      quad.at(2 * i + 1, 2 * jx) = luma.at(i, 2 * jx);     // G (row 2i+1, even)
+      quad.at(2 * i, 2 * jx + 1) = luma.at(i, 2 * jx + 1); // G (row 2i, odd)
+    }
+  }
+  size_t nc = std::min({c.w, d.w, w});
+  size_t hc = std::min({h, c.h, d.h});
+  for (size_t i = 0; i < hc; ++i) {
+    for (size_t jx = 0; jx < nc; ++jx) {
+      int64_t glo = (luma.at(i, 2 * jx) + luma.at(i, 2 * jx + 1)) >> 1;
+      quad.at(2 * i, 2 * jx) = glo + 2 * c.at(i, jx);         // R
+      quad.at(2 * i + 1, 2 * jx + 1) = glo + 2 * d.at(i, jx); // B
+    }
+  }
+  return quad;
+}
+
+} // namespace
+
+Arw6Decompressor::Arw6Decompressor(RawImage img, ByteStream input_, int compBd_)
+    : mRaw(std::move(img)), input(input_), compBd(compBd_) {
+  if (mRaw->getCpp() != 1 || mRaw->getDataType() != RawImageType::UINT16 ||
+      mRaw->getBpp() != sizeof(uint16_t))
+    ThrowRDE("Unexpected component count / data type");
+
+  if (!mRaw->dim.hasPositiveArea() || mRaw->dim.x % 2 != 0 ||
+      mRaw->dim.y % 2 != 0 || mRaw->dim.x > 11000 || mRaw->dim.y > 7000)
+    ThrowRDE("Unexpected image dimensions found: (%d; %d)", mRaw->dim.x,
+             mRaw->dim.y);
+
+  if (compBd != 12)
+    ThrowRDE("ARW6: unsupported compressed bit depth %d", compBd);
+}
+
+uint16_t Arw6Decompressor::blackLevel(int compBd) {
+  if (compBd == 12)
+    return 1024;
+  return 0;
+}
+
+uint16_t Arw6Decompressor::whiteLevel(int compBd) {
+  if (compBd == 12)
+    return 32800;
+  return 0;
+}
+
+void Arw6Decompressor::decompress() const {
+  const auto& curve = Arw6DelinCurveBd12;
+  const int64_t dc = static_cast<int64_t>(1) << (compBd - 1);
+  const int64_t maxv = (static_cast<int64_t>(1) << compBd) - 1;
+
+  const Buffer strip = input.peekRemainingBuffer();
+  const uint8_t* buf = strip.begin();
+  size_t buflen = strip.getSize();
+  if (buflen < 8)
+    ThrowRDE("ARW6: strip too short");
+
+  auto u32le = [&](size_t o) {
+    return static_cast<size_t>(buf[o]) | (static_cast<size_t>(buf[o + 1]) << 8) |
+           (static_cast<size_t>(buf[o + 2]) << 16) |
+           (static_cast<size_t>(buf[o + 3]) << 24);
+  };
+  size_t count = u32le(0);
+  if (count == 0 || count > 16)
+    ThrowRDE("ARW6: unexpected plane count %zu", count);
+
+  std::vector<size_t> offs;
+  offs.reserve(count);
+  for (size_t i = 0; i < count; ++i) {
+    if (8 + i * 24 + 4 > buflen)
+      ThrowRDE("ARW6: plane offset table truncated");
+    offs.push_back(u32le(8 + i * 24));
+  }
+
+  const size_t width = static_cast<size_t>(mRaw->dim.x);
+  const size_t height = static_cast<size_t>(mRaw->dim.y);
+  const size_t pw = width / 2;
+  const size_t ph = height / 2;
+  const size_t qw = pw; // quadrant width
+  const size_t qh = ph; // quadrant height
+
+  const Array2DRef<uint16_t> out(mRaw->getU16DataAsUncroppedArray2DRef());
+
+  // Quadrant tiling: plane0 TL, plane2 TR, plane1 BL, plane3 BR.
+  struct Tile {
+    size_t plane;
+    size_t r0;
+    size_t c0;
+  };
+  const std::array<Tile, 4> tiles = {
+      Tile{0, 0, 0}, Tile{2, 0, qw}, Tile{1, qh, 0}, Tile{3, qh, qw}};
+
+  const size_t nPlanes = std::min<size_t>(count, 4);
+
+#ifdef HAVE_OPENMP
+#pragma omp parallel for schedule(dynamic, 1) default(none)                     \
+    shared(tiles, offs, buf, buflen, out, curve)                               \
+    firstprivate(nPlanes, count, pw, ph, qw, qh, dc, maxv, width, height)      \
+    num_threads(rawspeed_get_number_of_processor_cores())
+#endif
+  for (int ti = 0; ti < static_cast<int>(nPlanes); ++ti) {
+    try {
+      const Tile& t = tiles[ti];
+      size_t pi = t.plane;
+      if (pi >= count)
+        continue;
+      size_t start = std::min(offs[pi], buflen);
+      size_t end = (pi + 1 < count) ? std::min(offs[pi + 1], buflen) : buflen;
+      if (end < start)
+        end = start;
+      const uint8_t* plane = buf + start;
+      size_t planeLen = end - start;
+
+      Plane a;
+      Plane c;
+      Plane d;
+      Plane b;
+      reconstructPlane(plane, planeLen, pw, ph, a, c, d, b);
+      Plane quad = assembleQuadrant(a, c, d, b);
+
+      if (quad.w != qw || quad.h != qh)
+        ThrowRDE("ARW6: quadrant size mismatch, expected %zux%zu, got %zux%zu",
+                 qw, qh, quad.w, quad.h);
+
+      // Linearize: out = curve[clamp(value + dc, 0, maxv)].
+      for (size_t r = 0; r < qh; ++r) {
+        for (size_t col = 0; col < qw; ++col) {
+          int64_t v = quad.at(r, col) + dc;
+          v = std::clamp<int64_t>(v, 0, maxv);
+          out(static_cast<int>(t.r0 + r), static_cast<int>(t.c0 + col)) =
+              curve[static_cast<size_t>(v)];
+        }
+      }
+    } catch (const RawspeedException& err) {
+      // Propagate the exception out of OpenMP magic.
+      mRaw->setError(err.what());
+    } catch (...) {
+      // We should not get any other exception type here.
+      __builtin_unreachable();
+    }
+  }
+
+  std::string firstErr;
+  if (mRaw->isTooManyErrors(1, &firstErr))
+    ThrowRDE("ARW6: too many errors. First: %s", firstErr.c_str());
+}
+
+} // namespace rawspeed
