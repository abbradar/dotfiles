+
+    You should have received a copy of the GNU Lesser General Public
+    License along with this library; if not, write to the Free Software
+    Foundation, Inc., 51 Franklin Street, Fifth Floor, Boston, MA 02110-1301 USA
+*/
+
+#pragma once
+
+#include "common/RawImage.h"
+#include "decompressors/AbstractDecompressor.h"
+#include "io/ByteStream.h"
+#include <cstdint>
+
+namespace rawspeed {
+
+class Arw6Decompressor final : public AbstractDecompressor {
+  RawImage mRaw;
+  ByteStream input;
+  int compBd;
+
+public:
+  Arw6Decompressor(RawImage img, ByteStream input, int compBd);
+  void decompress() const;
+
+  // Black and white levels of the linearized output for a given compressed bit
+  // depth, in the de-linearization curve's output scale, or 0 if unsupported.
+  //
+  // The ARW SR2 metadata black/white (512 / 15360) are in the pre-codec 14-bit
+  // scale and do not apply to the linearized mosaic. These are the levels the
+  // Adobe DNG Converter emits for the a7R VI "Compressed HQ" mode and are
+  // constant across files. Using the raw SR2 black (512) instead of 1024 leaves
+  // a pedestal that the per-channel white-balance gains amplify unevenly,
+  // producing a magenta cast.
+  static uint16_t blackLevel(int compBd);
+  static uint16_t whiteLevel(int compBd);
+};
+
+} // namespace rawspeed
