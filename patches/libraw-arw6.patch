+// ---------------------------------------------------------------------------
+// LibRaw entry point
+// ---------------------------------------------------------------------------
+void LibRaw::sony_arw6_load_raw()
+{
+#define ifp libraw_internal_data.internal_data.input
+  const unsigned dataOffset = libraw_internal_data.unpacker_data.data_offset;
+  const unsigned dataSize = libraw_internal_data.unpacker_data.data_size;
+
+  // ARW6 (Sony LLVC v3 "Compressed HQ") is a single strip at data_offset.
+  // Only the compressed bit depth 12 (a7R V / a1 / a7R VI) has a known curve.
+  const int compBd = 12;
+  const i64 dc = (i64)1 << (compBd - 1);
+  const i64 maxv = ((i64)1 << compBd) - 1;
+
+  if (dataSize < 8)
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+  if (dataSize > 1024u * 1024u * 1024u)
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+
+  std::vector<uint8_t> strip(dataSize);
+  ifp->seek(dataOffset, SEEK_SET);
+  if (ifp->read(strip.data(), 1, dataSize) != (int)dataSize)
+    throw LIBRAW_EXCEPTION_IO_EOF;
+  const uint8_t *buf = strip.data();
+  size_t buflen = strip.size();
+#undef ifp
+
+  // The strip header / plane offset table is little-endian; read it through the
+  // bounds-checked buffer (throws on a truncated table).
+  checked_buffer_t scb(0x4949, strip.data(), (int)dataSize);
+  size_t count = scb.sget4(0);
+  if (count == 0 || count > 16)
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+
+  // Per-plane strip record: 24 bytes at `8 + i*24` = (byteOffset, _, x, y, W, H)
+  // as u32le. (x, y) is the plane's top-left in the Bayer mosaic; (W, H) its
+  // size in mosaic pixels. Tiles are NOT necessarily equal halves (e.g. a
+  // 10016-wide sensor can split 5024 + 4992), so per-plane W/H must be read.
+  struct PlaneInfo
+  {
+    size_t off, x, y, w, h;
+  };
+  std::vector<PlaneInfo> planeInfos;
+  planeInfos.reserve(count);
+  for (size_t i = 0; i < count; ++i)
+  {
+    int rec = (int)(8 + i * 24);
+    PlaneInfo pi;
+    pi.off = scb.sget4(rec);
+    pi.x = scb.sget4(rec + 8);
+    pi.y = scb.sget4(rec + 12);
+    pi.w = scb.sget4(rec + 16);
+    pi.h = scb.sget4(rec + 20);
+    planeInfos.push_back(pi);
+  }
+
+  const size_t W = (size_t)imgdata.sizes.raw_width;
+  const size_t H = (size_t)imgdata.sizes.raw_height;
+
+  for (size_t ti = 0; ti < count; ++ti)
+  {
+    checkCancel();
+    const PlaneInfo &pinfo = planeInfos[ti];
+    const size_t pw = pinfo.w;
+    const size_t ph = pinfo.h;
+    if (pw == 0 || ph == 0 || (pw & 1) || (ph & 1) || pinfo.x + pw > W ||
+        pinfo.y + ph > H)
+      throw LIBRAW_EXCEPTION_IO_CORRUPT;
+    size_t start = std::min(pinfo.off, buflen);
+    size_t end = (ti + 1 < count) ? std::min(planeInfos[ti + 1].off, buflen)
+                                  : buflen;
+    if (end < start)
+      end = start;
+    const uint8_t *plane = buf + start;
+    size_t planeLen = end - start;
+
+    Plane a, c, d, b;
+    reconstructPlane(plane, planeLen, pw, ph, a, c, d, b);
+    Plane quad = assembleQuadrant(a, c, d, b);
+
+    if (quad.w != pw || quad.h != ph)
+      throw LIBRAW_EXCEPTION_IO_CORRUPT;
+
+    // Linearize: raw = curve[clamp(value + dc, 0, maxv)]; place at (x, y).
+    for (size_t r = 0; r < ph; ++r)
+    {
+      for (size_t col = 0; col < pw; ++col)
+      {
+        i64 v = LIM(quad.at(r, col) + dc, (i64)0, maxv);
+        imgdata.rawdata.raw_image[(pinfo.y + r) * W + (pinfo.x + col)] =
+            Arw6DelinCurveBd12[(size_t)v];
+      }
+    }
+  }
+
+  // The output is linearized through the codec curve, so the black/white points
+  // are in the curve's output scale, not the ARW SR2 metadata scale (the
+  // pre-codec 14-bit domain). Using the SR2 black (512) leaves a pedestal the
+  // white-balance gains turn into a magenta cast.
+  imgdata.color.maximum = 32800;
+  imgdata.color.black = 1024;
+  for (int i = 0; i < 4; i++)
+    imgdata.color.cblack[i] = 0;
+  imgdata.color.cblack[4] = imgdata.color.cblack[5] = 0;
+}
