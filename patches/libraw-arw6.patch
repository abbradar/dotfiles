diff --git a/src/decoders/sonyarw6.cpp b/src/decoders/sonyarw6.cpp
new file mode 100644
index 0000000..01d00bf
--- /dev/null
+++ b/src/decoders/sonyarw6.cpp
@@ -0,0 +1,970 @@
+/* -*- C++ -*-
+ * File: sonyarw6.cpp
+ * Copyright (C) 2024-2025 LibRaw LLC (info@libraw.org)
+ *
+   Sony LLVC v3 ("Compressed HQ", ARW compression tag 32766) decoder.
+
+   Reverse-engineered from the Adobe DNG Converter `sony_llvc3_dec` and ported
+   from a verified prototype (bit-exact against the Adobe oracle). The codec is
+   a line-based inverse-wavelet pipeline: per spatial-quadrant plane it decodes
+   four wavelet components -- A (luma low band, 4-level 2D 5/3 wavelet), B (luma
+   full-resolution highpass), and C, D (the two chroma difference bands) -- with
+   an adaptive entropy coder, a flipped 5/3 vertical lifting, and a Sony-specific
+   luma/chroma combine, then linearizes through a baked codec curve.
+
+LibRaw is free software; you can redistribute it and/or modify
+it under the terms of the one of two licenses as you choose:
+
+1. GNU LESSER GENERAL PUBLIC LICENSE version 2.1
+   (See file LICENSE.LGPL provided in LibRaw distribution archive for details).
+
+2. COMMON DEVELOPMENT AND DISTRIBUTION LICENSE (CDDL) Version 1.0
+   (See file LICENSE.CDDL provided in LibRaw distribution archive for details).
+
+ */
+
+#include "../../internal/libraw_cxx_defs.h"
+#include "../../internal/losslessjpeg.h"     // BitPump generic bit source
+#include "../../internal/libraw_checked_buffer.h"
+#include "sonyarw6_curve.h"
+#include <vector>
+#include <algorithm>
+#include <cstdint>
+
+namespace
+{
+
+typedef int64_t i64;
+
+// ---------------------------------------------------------------------------
+// Bitstream reader: MSB-first over a byte buffer, zero-filling past the end so
+// the one unbounded construct (the adaptive-k zero-run) terminates instead of
+// consuming the zero-filled tail forever.
+//
+// Implements LibRaw's generic BitPump interface (internal/losslessjpeg.h),
+// reusing its get(); unlike BitPumpJpeg it does no 0xFF byte-stuffing, matching
+// this codec's plain bitstream. readZeros()/byteAlign() are the two extras the
+// codec needs on top.
+// ---------------------------------------------------------------------------
+struct BitPumpMSB : public BitPump
+{
+  const uint8_t *buffer;
+  size_t size; // length of the real (non-zero-fill) input, in bytes
+  size_t pos;  // next byte to load
+  uint64_t bits;
+  uint32_t nbits; // valid (unconsumed) bits cached in the low bits of `bits`
+
+  BitPumpMSB(const uint8_t *b, size_t s)
+      : buffer(b), size(s), pos(0), bits(0), nbits(0)
+  {
+  }
+
+  uint32_t peek(uint32_t num) override
+  {
+    while (nbits < num)
+    {
+      uint8_t b = (pos < size) ? buffer[pos] : 0; // zero-fill past end
+      ++pos;
+      bits = (bits << 8) | (uint64_t)b;
+      nbits += 8;
+    }
+    return uint32_t(bits >> (nbits - num));
+  }
+  void consume(uint32_t num) override
+  {
+    nbits -= num;
+    bits &= (uint64_t(1) << nbits) - 1ULL;
+  }
+
+  // Codec-facing aliases over the shared BitPump::get().
+  inline uint32_t rd1() { return get(1); }
+  inline uint32_t rdn(uint32_t n) { return get(n); }
+
+  // Total number of bits consumed from the real stream so far.
+  inline i64 consumedBits() const { return (i64)pos * 8 - nbits; }
+
+  // Count the run of 0 bits up to the next 1 bit (consuming the 1).
+  // Returns -1 if the stream ends before a 1 bit is found.
+  inline i64 readZeros()
+  {
+    i64 cnt = 0;
+    while (consumedBits() < (i64)size * 8)
+    {
+      if (get(1) == 1)
+        return cnt;
+      ++cnt;
+    }
+    return -1;
+  }
+
+  // Discard bits up to the next whole-byte boundary in the stream.
+  inline void alignByte() { consume(nbits & 7); }
+};
+
+// ---------------------------------------------------------------------------
+// Entropy decode
+// ---------------------------------------------------------------------------
+
+// Mid-rise dequantizer: ((2*mag+1) << (q-1)) - (mag & 1), clamped to i32 max.
+inline i64 dequant(i64 mag, i64 q)
+{
+  if (mag <= 0 || q <= 0)
+    return mag;
+  i64 r = ((2 * mag + 1) << (q - 1)) - (mag & 1);
+  return r > 0x7fffffff ? 0x7fffffff : r;
+}
+
+// Adaptively update the magnitude-bit count k.
+i64 updateK(BitPumpMSB &r, i64 k)
+{
+  if (r.rd1() == 0)
+    return k;
+  if (r.rd1() == 0)
+  {
+    // increase: k += 1 + run(0s). EOF before the terminating 1 -> k unchanged.
+    i64 z = r.readZeros();
+    return z >= 0 ? k + 1 + z : k;
+  }
+  // decrease: drop k by 1 per 0-bit until a 1-bit, bounded by k reaching 0.
+  if (k <= 0)
+    return 0;
+  k -= 1;
+  while (k >= 1)
+  {
+    if (r.rd1() == 1)
+      return k;
+    k -= 1;
+  }
+  return k;
+}
+
+inline uint32_t bitLength(i64 x)
+{
+  uint32_t c = 0;
+  while (x > 0)
+  {
+    x >>= 1;
+    ++c;
+  }
+  return c;
+}
+
+// Read a capped unary prefix used for zero-run lengths.
+i64 readUnaryCapped(BitPumpMSB &r, i64 remaining)
+{
+  if (remaining < 2)
+    return 0;
+  i64 cap = (i64)bitLength(remaining - 1);
+  i64 cnt = 0;
+  while (cnt < cap)
+  {
+    if (r.rd1() == 1)
+      return cnt;
+    ++cnt;
+  }
+  return cnt;
+}
+
+// Decode one 4-coefficient group into out[base..base+4]; return the new k.
+i64 decodeGroup(BitPumpMSB &r, i64 k, i64 q, bool notLast, std::vector<i64> &out,
+                size_t base)
+{
+  i64 m0, m1, m2, m3;
+  if (k <= 0)
+  {
+    m0 = m1 = m2 = m3 = 0;
+  }
+  else if (k < 8)
+  {
+    uint64_t v = r.rdn((uint32_t)(k * 4));
+    uint64_t m = (1ULL << k) - 1;
+    m0 = (i64)((v >> (3 * k)) & m);
+    m1 = (i64)((v >> (2 * k)) & m);
+    m2 = (i64)((v >> k) & m);
+    m3 = (i64)(v & m);
+  }
+  else
+  {
+    m0 = (i64)r.rdn((uint32_t)k);
+    m1 = (i64)r.rdn((uint32_t)k);
+    m2 = (i64)r.rdn((uint32_t)k);
+    m3 = (i64)r.rdn((uint32_t)k);
+  }
+  i64 v0 = dequant(m0, q);
+  i64 v1 = dequant(m1, q);
+  i64 v2 = dequant(m2, q);
+  i64 v3 = dequant(m3, q);
+  bool nz0 = m0 > 0, nz1 = m1 > 0, nz2 = m2 > 0, nz3 = m3 > 0;
+  i64 newK = notLast ? updateK(r, k) : k;
+  uint32_t nsign = (uint32_t)nz0 + (uint32_t)nz1 + (uint32_t)nz2 + (uint32_t)nz3;
+  uint64_t sb = nsign > 0 ? r.rdn(nsign) : 0;
+  uint32_t idx = 0;
+  if (nz0)
+  {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v0 = -v0;
+    ++idx;
+  }
+  if (nz1)
+  {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v1 = -v1;
+    ++idx;
+  }
+  if (nz2)
+  {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v2 = -v2;
+    ++idx;
+  }
+  if (nz3)
+  {
+    if (((sb >> (nsign - 1 - idx)) & 1) == 1)
+      v3 = -v3;
+  }
+  out[base] = v0;
+  out[base + 1] = v1;
+  out[base + 2] = v2;
+  out[base + 3] = v3;
+  return newK;
+}
+
+// Decode a full detail line into out[0..4*groups]; out is fully overwritten.
+void decodeLineDetail(BitPumpMSB &r, size_t groups, i64 q, std::vector<i64> &out)
+{
+  for (size_t i = 0; i < 4 * groups; ++i)
+    out[i] = 0;
+  i64 k = updateK(r, 0);
+  size_t g = 0;
+  while (g < groups)
+  {
+    if (k == 0)
+    {
+      i64 rem = (i64)(groups - g);
+      if (rem == 1)
+      {
+        g += 1;
+        continue;
+      }
+      i64 e = readUnaryCapped(r, rem);
+      i64 run = (i64)1 << e;
+      if (run < rem)
+      {
+        if (e > 0)
+          run += (i64)r.rdn((uint32_t)e) & (((i64)1 << e) - 1);
+        if (run < 0 || rem < run)
+          break; // inconsistent zero-run length: only on corrupt input
+        g += (size_t)run;
+        i64 z = r.readZeros();
+        if (z < 0)
+          break;
+        k += 1 + z;
+        if (k >= 0x14)
+          break;
+      }
+      else
+      {
+        break;
+      }
+    }
+    else
+    {
+      k = decodeGroup(r, k, q, g < groups - 1, out, 4 * g);
+      g += 1;
+    }
+  }
+}
+
+// Wrap to signed 16-bit (the binary stores intermediate coefficients as i16).
+inline i64 i16wrap(i64 v)
+{
+  v &= 0xffff;
+  return v >= 0x8000 ? v - 0x10000 : v;
+}
+
+// Horizontal cumulative-sum prediction for the LL band, with int16 wraparound.
+// line[0] is unchanged.
+void predictHorizontal(i64 *line, size_t n)
+{
+  i64 acc = i16wrap(line[0] * 2);
+  for (size_t i = 1; i < n; ++i)
+  {
+    acc = i16wrap(line[i] * 2 + acc);
+    line[i] = acc >> 1;
+  }
+}
+
+// ---------------------------------------------------------------------------
+// 2D plane of i64 coefficients/samples (row-major)
+// ---------------------------------------------------------------------------
+struct Plane
+{
+  size_t w, h;
+  std::vector<i64> data;
+
+  Plane() : w(0), h(0) {}
+  Plane(size_t w_, size_t h_) : w(w_), h(h_), data(w_ * h_, 0) {}
+
+  inline i64 at(size_t r, size_t c) const { return data[r * w + c]; }
+  inline i64 &at(size_t r, size_t c) { return data[r * w + c]; }
+};
+
+// ---------------------------------------------------------------------------
+// Inverse wavelet transform
+// ---------------------------------------------------------------------------
+
+// Standard inverse 5/3 lifting along axis 0 (rows): coarse at even outputs.
+Plane idwt53(const Plane &low, const Plane &high)
+{
+  size_t w = low.w;
+  size_t nl = low.h;
+  size_t nh = high.h;
+  size_t n = nl + nh;
+  size_t ne = (n + 1) / 2;
+  Plane x(w, n);
+  for (size_t nn = 0; nn < std::min(nl, ne); ++nn)
+  {
+    for (size_t c = 0; c < w; ++c)
+    {
+      i64 dm1 = (nn > 0 && nn <= nh) ? high.at(nn - 1, c)
+                : (nh > 0)           ? high.at(0, c)
+                                     : 0;
+      i64 d0 = (nn < nh)  ? high.at(nn, c)
+               : (nh > 0) ? high.at(nh - 1, c)
+                          : 0;
+      x.at(2 * nn, c) = low.at(nn, c) - ((dm1 + d0 + 2) >> 2);
+    }
+  }
+  for (size_t nn = 0; nn < std::min(nh, n / 2); ++nn)
+  {
+    for (size_t c = 0; c < w; ++c)
+    {
+      i64 a = x.at(2 * nn, c);
+      i64 b = (2 * nn + 2 < n) ? x.at(2 * nn + 2, c) : a;
+      x.at(2 * nn + 1, c) = high.at(nn, c) + ((a + b) >> 1);
+    }
+  }
+  return x;
+}
+
+// Inverse 5/3 with flipped polyphase: detail at even outputs, coarse at odd.
+// Matches the binary's vertical lift when the detail-row count is odd.
+Plane idwt53Flip(const Plane &low, const Plane &high)
+{
+  size_t w = low.w;
+  size_t nl = low.h;
+  size_t nh = high.h;
+  size_t n = nl + nh;
+  Plane lo = low;
+  Plane hi = high;
+  for (size_t nn = 0; nn < nl; ++nn)
+  {
+    for (size_t c = 0; c < w; ++c)
+    {
+      i64 h0 = (nn < nh) ? hi.at(nn, c) : hi.at(nh - 1, c);
+      i64 h1 = (nn + 1 < nh) ? hi.at(nn + 1, c) : hi.at(nh - 1, c);
+      lo.at(nn, c) -= (h0 + h1 + 2) >> 2;
+    }
+  }
+  for (size_t nn = 0; nn < nh; ++nn)
+  {
+    for (size_t c = 0; c < w; ++c)
+    {
+      i64 l0 = (nn >= 1) ? lo.at(nn - 1, c) : lo.at(0, c);
+      i64 l1 = (nn < nl) ? lo.at(nn, c) : lo.at(nl - 1, c);
+      hi.at(nn, c) += (l0 + l1) >> 1;
+    }
+  }
+  Plane x(w, n);
+  for (size_t nn = 0; nn < nh; ++nn)
+    if (2 * nn < n)
+      for (size_t c = 0; c < w; ++c)
+        x.at(2 * nn, c) = hi.at(nn, c);
+  for (size_t nn = 0; nn < nl; ++nn)
+    if (2 * nn + 1 < n)
+      for (size_t c = 0; c < w; ++c)
+        x.at(2 * nn + 1, c) = lo.at(nn, c);
+  return x;
+}
+
+// Vertical inverse 5/3: phase chosen by detail-row-count parity (from header
+// geometry, not hardcoded): odd -> flipped polyphase, even -> standard.
+Plane vidwt(const Plane &low, const Plane &high)
+{
+  return (high.h & 1) == 1 ? idwt53Flip(low, high) : idwt53(low, high);
+}
+
+Plane transpose(const Plane &p)
+{
+  Plane t(p.h, p.w); // new dims: w'=p.h, h'=p.w
+  for (size_t r = 0; r < p.h; ++r)
+    for (size_t c = 0; c < p.w; ++c)
+      t.at(c, r) = p.at(r, c);
+  return t;
+}
+
+Plane crop(const Plane &p, size_t h, size_t w)
+{
+  Plane o(w, h);
+  for (size_t r = 0; r < h; ++r)
+    std::copy(&p.data[r * p.w], &p.data[r * p.w] + w, &o.data[r * w]);
+  return o;
+}
+
+// One level of 2D inverse 5/3: vertical pass per column-pair, then horizontal.
+// lh/hl/hh are the three detail orientations.
+Plane idwt2d(const Plane &ll, const Plane &lh, const Plane &hl, const Plane &hh)
+{
+  Plane left = vidwt(ll, lh);
+  Plane right = vidwt(hl, hh);
+  size_t nr = std::min(left.h, right.h);
+  size_t nc = std::min(left.w, right.w);
+  Plane lt = transpose(crop(left, nr, nc));
+  Plane rt = transpose(crop(right, nr, nc));
+  // Horizontal pass: inverse 5/3 along the (transposed) rows, then transpose.
+  return transpose(idwt53(lt, rt));
+}
+
+// Fused vertical IDWT + horizontal upsample combining comp A (V-low) and comp B
+// (V-high) into the luma plane (H x 2W). Top boundary reflects (line[-1].hi =
+// B[0]); the final output row reflects the bottom.
+Plane streamLuma(const Plane &a, const Plane &b)
+{
+  size_t h = a.h;
+  size_t w = a.w;
+  Plane lo(w, h);
+  Plane hi(w, h);
+  Plane luma(2 * w, h);
+  for (size_t r = 0; r < h; ++r)
+  {
+    for (size_t n = 0; n < w; ++n)
+      hi.at(r, n) = b.at(r, n);
+    for (size_t n = 0; n + 1 < w; ++n)
+    {
+      i64 ph0 = (r >= 1) ? hi.at(r - 1, n) : b.at(r, n);
+      i64 ph1 = (r >= 1) ? hi.at(r - 1, n + 1) : b.at(r, n + 1);
+      i64 s = b.at(r, n) + b.at(r, n + 1) + ph0 + ph1;
+      lo.at(r, n) = i16wrap((2 * a.at(r, n) - (s >> 2)) >> 1);
+    }
+    i64 phl = (r >= 1) ? hi.at(r - 1, w - 1) : b.at(r, w - 1);
+    i64 s = 2 * (b.at(r, w - 1) + phl);
+    lo.at(r, w - 1) = i16wrap((2 * a.at(r, w - 1) - (s >> 2)) >> 1);
+  }
+  for (size_t r = 1; r < h; ++r)
+  {
+    luma.at(r - 1, 0) =
+        i16wrap((((lo.at(r, 0) + lo.at(r - 1, 0)) * 2) >> 2) + hi.at(r - 1, 0));
+    luma.at(r - 1, 1) = lo.at(r - 1, 0);
+    for (size_t i = 1; i < w; ++i)
+    {
+      i64 ev = i16wrap(((lo.at(r, i - 1) + lo.at(r, i) + lo.at(r - 1, i - 1) +
+                         lo.at(r - 1, i)) >>
+                        2) +
+                       hi.at(r - 1, i));
+      luma.at(r - 1, 2 * i) = ev;
+      luma.at(r - 1, 2 * i + 1) = lo.at(r - 1, i);
+    }
+  }
+  // Last output row: bottom boundary reflects (line[H] = line[H-1] -> rbB=rbA).
+  size_t r = h - 1;
+  luma.at(r, 0) = i16wrap(((lo.at(r, 0) * 2) >> 2) + hi.at(r, 0));
+  luma.at(r, 1) = lo.at(r, 0);
+  for (size_t i = 1; i < w; ++i)
+  {
+    i64 ev = i16wrap(((2 * (lo.at(r, i - 1) + lo.at(r, i))) >> 2) + hi.at(r, i));
+    luma.at(r, 2 * i) = ev;
+    luma.at(r, 2 * i + 1) = lo.at(r, i);
+  }
+  return luma;
+}
+
+// ---------------------------------------------------------------------------
+// Plane header parsing and band geometry
+// ---------------------------------------------------------------------------
+
+// Row window of one subband orientation: rows [top, bot) with phase rowbase.
+struct Geom
+{
+  i64 top, bot, rowbase;
+};
+
+// Geometry of one band (1 orientation for LL / comp B, 3 for detail levels).
+struct BandGeom
+{
+  size_t width;
+  i64 stride;
+  std::vector<Geom> geoms;
+  bool cumsum;
+  BandGeom() : width(0), stride(1), cumsum(false) {}
+};
+
+struct Geometry
+{
+  BandGeom ll;
+  BandGeom b;
+  std::vector<BandGeom> detail; // indexed by vertical level v; valid for 2..=j
+};
+
+struct Record
+{
+  size_t count;
+  std::vector<i64> ents;
+};
+
+// 24-bit big-endian read at a bounds-checked offset (the plane header stores
+// the level totals and record entries this way).
+inline i64 u24be(checked_buffer_t &cb, int o)
+{
+  return ((i64)cb[o] << 16) | ((i64)cb[o + 1] << 8) | (i64)cb[o + 2];
+}
+
+// Parse the plane header: the five level totals and the per-level record table.
+// The plane sub-header sits at plane+0x10; all reads go through the bounds-
+// checked buffer, which throws on a truncated/malformed header.
+void parseHeader(checked_buffer_t &cb, std::vector<i64> &totals,
+                 std::vector<Record> &recs)
+{
+  const int base = 0x10;
+  static const int kTotOff[5] = {0, 3, 6, 9, 12};
+  totals.clear();
+  for (int i = 0; i < 5; ++i)
+    totals.push_back(u24be(cb, base + kTotOff[i]) << 4);
+  recs.clear();
+  int pos = 0x20;
+  static const int kOff1[5] = {1, 4, 7, 10, 13};
+  static const int kOff2[4] = {0x11, 0x14, 0x17, 0x1a};
+  for (int i = 0; i < 5; ++i)
+  {
+    size_t count = cb[base + pos] & 0xf;
+    Record rec;
+    rec.count = count;
+    for (size_t j = 0; j < std::min<size_t>(count, 5); ++j)
+      rec.ents.push_back(u24be(cb, base + pos + kOff1[j]) << 4);
+    int adv = 0x10;
+    if (count >= 5)
+    {
+      for (size_t j = 0; j < count - 5; ++j)
+        rec.ents.push_back(u24be(cb, base + pos + kOff2[j]) << 4);
+      adv = 0x20;
+    }
+    recs.push_back(rec);
+    pos += adv;
+  }
+}
+
+// Byte offset (in plane bytes) where the band bitstream begins: 0x10 (plane
+// sub-header) + 0x20 (the level-totals block) + the record-table strides (0x10
+// per record, 0x20 when the count nibble >= 5).
+size_t bitstreamBase(checked_buffer_t &cb)
+{
+  const int base = 0x10;
+  int pos = 0x20;
+  for (int i = 0; i < 5; ++i)
+  {
+    size_t count = cb[base + pos] & 0xf;
+    pos += (count >= 5) ? 0x20 : 0x10;
+  }
+  return base + pos;
+}
+
+// Byte offset of band (region, comp) within the plane entropy buffer.
+size_t bandOffset(const std::vector<i64> &totals, const std::vector<Record> &recs,
+                  size_t region, size_t comp)
+{
+  i64 base = 0;
+  for (size_t i = 0; i < region; ++i)
+    base += totals[i];
+  for (size_t c = 0; c < comp; ++c)
+    base += recs[region].ents[c];
+  return (size_t)base;
+}
+
+// Header region index for a detail band at vertical level v.
+inline size_t detailRegion(size_t v, size_t j) { return j - v + 1; }
+
+// Derive all band geometry from the plane dimensions and level count j.
+Geometry deriveGeom(size_t pw, size_t ph, size_t j)
+{
+  i64 pwi = (i64)pw;
+  std::vector<i64> splitLo(j + 1, 0);
+  std::vector<i64> splitHi(j + 1, 0);
+  i64 cur = (i64)ph;
+  for (size_t v = 1; v <= j; ++v)
+  {
+    splitLo[v] = (cur + 1) / 2;
+    splitHi[v] = cur / 2;
+    cur = (cur + 1) / 2;
+  }
+  std::vector<i64> top0(j + 1, 0);
+  std::vector<i64> top1(j + 1, 0);
+  top0[1] = 2 * (i64)j + 2;
+  for (size_t v = 2; v <= j; ++v)
+    top0[v] = (top0[v - 1] + 1) / 2;
+  if (j >= 2)
+    top1[2] = top0[1] / 2;
+  for (size_t v = 3; v <= j; ++v)
+    top1[v] = top1[v - 1] / 2;
+  i64 rbb = (i64)1 << ((i64)j - 2);
+  Geometry geo;
+  geo.detail.assign(j + 1, BandGeom());
+  for (size_t v = 1; v <= j; ++v)
+  {
+    size_t wd = (size_t)(pwi >> v);
+    i64 st = (i64)1 << ((i64)j - (i64)v);
+    i64 lo = splitLo[v];
+    i64 hi = splitHi[v];
+    i64 rb0 = std::max<i64>(1, rbb >> ((i64)v - 1));
+    i64 rb1 = rbb >> ((i64)v - 1);
+    if (v == 1)
+    {
+      geo.b.width = wd;
+      geo.b.stride = st;
+      geo.b.geoms.assign(1, Geom());
+      geo.b.geoms[0].top = top0[1];
+      geo.b.geoms[0].bot = top0[1] + hi;
+      geo.b.geoms[0].rowbase = rb0;
+      geo.b.cumsum = false;
+    }
+    else
+    {
+      BandGeom bg;
+      bg.width = wd;
+      bg.stride = st;
+      bg.cumsum = false;
+      Geom g0 = {top0[v], top0[v] + hi, rb0};
+      Geom g1 = {top1[v], top1[v] + lo, rb1};
+      Geom g2 = {top1[v], top1[v] + lo, rb1};
+      bg.geoms.push_back(g0);
+      bg.geoms.push_back(g1);
+      bg.geoms.push_back(g2);
+      geo.detail[v] = bg;
+    }
+  }
+  i64 hiJ = splitHi[j];
+  i64 rb0j = std::max<i64>(1, rbb >> ((i64)j - 1));
+  geo.ll.width = (size_t)(pwi >> j);
+  geo.ll.stride = 1;
+  geo.ll.cumsum = true;
+  geo.ll.geoms.assign(1, Geom());
+  geo.ll.geoms[0].top = top0[j];
+  geo.ll.geoms[0].bot = top0[j] + hiJ;
+  geo.ll.geoms[0].rowbase = rb0j;
+  return geo;
+}
+
+// Parse a band's 16-byte header at buf[off]. Returns the entropy-slice offset
+// and the per-orientation quantizers, read MSB-first.
+//
+//   16b A | 24b sizeB | 4b magic1(=4) | 4b magic2(=0) | 2b mode | 6b _ |
+//   16b N | 8b (=0x10) | 8b (=0) | 40b _
+//
+// size = (A + 1) * 16 is the total header+table byte size; the entropy slices
+// begin at off + size. mode is the orientation count (1 for LL & comp B, 3 for
+// detail = HL/LH/HH). Read order q[0]=HL, q[1]=LH, q[2]=HH.
+bool bandHeader(const uint8_t *buf, size_t buflen, size_t off, size_t &entOut,
+                std::vector<i64> &qOut)
+{
+  size_t avail = off < buflen ? buflen - off : 0;
+  BitPumpMSB r(buf + std::min(off, buflen), avail);
+  i64 a = (i64)r.rdn(16);
+  r.rdn(24); // sizeB (unused)
+  uint32_t m1 = (uint32_t)r.rdn(4);
+  uint32_t m2 = (uint32_t)r.rdn(4);
+  size_t mode = (size_t)r.rdn(2);
+  r.rdn(6);
+  i64 n = (i64)r.rdn(16);
+  uint32_t b9 = (uint32_t)r.rdn(8);
+  uint32_t b10 = (uint32_t)r.rdn(8);
+  r.rdn(32);
+  r.rdn(8); // 40b reserved (split to stay within a 32-bit read)
+  if (!(m1 == 4 && m2 == 0 && b9 == 0x10 && b10 == 0 &&
+        a == (((i64)mode + 4) * n * 4 + 0x7f) >> 7))
+    return false;
+  r.rdn(16); // entry-0 slice length (unused; entropy is self-delimiting)
+  qOut.clear();
+  qOut.reserve(mode);
+  for (size_t i = 0; i < mode; ++i)
+    qOut.push_back((i64)r.rdn(4));
+  entOut = off + ((size_t)a + 1) * 16;
+  return true;
+}
+
+// ---------------------------------------------------------------------------
+// Band decode + plane reconstruction
+// ---------------------------------------------------------------------------
+
+inline size_t roundUpDiv(size_t a, size_t b) { return (a + b - 1) / b; }
+
+// Decode one band into its orientation planes (1 for LL / comp B, 3 for detail).
+std::vector<Plane> decodeBandContig(const uint8_t *buf, size_t buflen,
+                                    size_t regionOff, size_t width, i64 stride,
+                                    const std::vector<i64> &qOrients,
+                                    const std::vector<Geom> &geoms, bool cumsum)
+{
+  size_t groups = roundUpDiv(width, 4);
+  size_t no = geoms.size();
+  std::vector<std::vector<i64> > orientData(no);
+  std::vector<size_t> orientH(no, 0);
+  std::vector<i64> out(4 * groups, 0);
+  size_t off = std::min(regionOff, buflen);
+  BitPumpMSB r(buf + off, buflen - off);
+  i64 row = 0;
+  i64 maxr = 0;
+  for (size_t gi = 0; gi < no; ++gi)
+    maxr = std::max(maxr, (geoms[gi].bot - geoms[gi].rowbase) / stride + 3);
+  while (row < maxr)
+  {
+    std::vector<i64> ns(no);
+    i64 total = 0;
+    for (size_t o = 0; o < no; ++o)
+    {
+      const Geom &g = geoms[o];
+      i64 n = std::max<i64>(0, std::min(g.bot, g.rowbase + row * stride + stride) -
+                                   std::max(g.top, g.rowbase + row * stride));
+      ns[o] = n;
+      total += n;
+    }
+    if (total == 0)
+    {
+      bool allDone = true;
+      for (size_t o = 0; o < no; ++o)
+        if (geoms[o].rowbase + row * stride < geoms[o].bot)
+          allDone = false;
+      if (allDone)
+        break;
+      row += 1;
+      continue;
+    }
+    r.alignByte();
+    for (size_t o = 0; o < no; ++o)
+    {
+      for (i64 i = 0; i < ns[o]; ++i)
+      {
+        decodeLineDetail(r, groups, qOrients[o], out);
+        size_t start = orientData[o].size();
+        orientData[o].insert(orientData[o].end(), out.begin(),
+                             out.begin() + width);
+        if (cumsum)
+          predictHorizontal(&orientData[o][start], width);
+        orientH[o] += 1;
+      }
+    }
+    row += 1;
+  }
+  std::vector<Plane> planes;
+  planes.reserve(no);
+  for (size_t o = 0; o < no; ++o)
+  {
+    Plane p;
+    p.w = width;
+    p.h = orientH[o];
+    p.data.swap(orientData[o]);
+    planes.push_back(p);
+  }
+  return planes;
+}
+
+// Reconstruct the four wavelet components (A, C, D, B) of one plane.
+void reconstructPlane(const uint8_t *plane, size_t planeLen, size_t pw, size_t ph,
+                      Plane &a, Plane &c, Plane &d, Plane &bband)
+{
+  if (planeLen > (size_t)INT_MAX)
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+  // Bounds-checked view of the plane bytes for the header parse (little-endian
+  // order is irrelevant here -- all header reads are big-endian via u24be()).
+  checked_buffer_t cb(0x4949, const_cast<uchar *>(plane), (int)planeLen);
+  std::vector<i64> totals;
+  std::vector<Record> recs;
+  parseHeader(cb, totals, recs);
+  size_t j = totals.size() - 1;
+  Geometry geo = deriveGeom(pw, ph, j);
+  size_t base = bitstreamBase(cb);
+  if (planeLen < base)
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+  const uint8_t *buf = plane + base;
+  size_t buflen = planeLen - base;
+
+  Plane comps[3];
+  for (size_t comp = 0; comp < 3; ++comp)
+  {
+    const BandGeom &gll = geo.ll;
+    size_t bo = bandOffset(totals, recs, 0, comp);
+    size_t ent;
+    std::vector<i64> q;
+    if (!bandHeader(buf, buflen, bo, ent, q))
+      throw LIBRAW_EXCEPTION_IO_CORRUPT;
+    Plane img = decodeBandContig(buf, buflen, ent, gll.width, gll.stride, q,
+                                 gll.geoms, gll.cumsum)[0];
+    for (size_t v = j; v >= 2; --v)
+    {
+      size_t region = detailRegion(v, j);
+      if (comp >= recs[region].count)
+        break;
+      const BandGeom &g = geo.detail[v];
+      size_t bo2 = bandOffset(totals, recs, region, comp);
+      size_t ent2;
+      std::vector<i64> q2;
+      if (!bandHeader(buf, buflen, bo2, ent2, q2))
+        throw LIBRAW_EXCEPTION_IO_CORRUPT;
+      std::vector<Plane> dd = decodeBandContig(buf, buflen, ent2, g.width,
+                                               g.stride, q2, g.geoms, g.cumsum);
+      // Orientation mapping: ll, lh=dd[1], hl=dd[0], hh=dd[2].
+      img = idwt2d(img, dd[1], dd[0], dd[2]);
+    }
+    comps[comp] = img;
+  }
+
+  // comp B (region 4): single full-res highpass band (q from header).
+  const BandGeom &gb = geo.b;
+  size_t bo = bandOffset(totals, recs, 4, 0);
+  size_t entb;
+  std::vector<i64> qb;
+  if (!bandHeader(buf, buflen, bo, entb, qb))
+    throw LIBRAW_EXCEPTION_IO_CORRUPT;
+  bband = decodeBandContig(buf, buflen, entb, gb.width, gb.stride, qb, gb.geoms,
+                           gb.cumsum)[0];
+  a = comps[0];
+  c = comps[1];
+  d = comps[2];
+}
+
+// Assemble one quadrant's CFA mosaic (2H x 2W, RGGB) from the components.
+Plane assembleQuadrant(const Plane &a, const Plane &c, const Plane &d,
+                       const Plane &b)
+{
+  size_t h = std::min(a.h, b.h);
+  size_t w = a.w;
+  Plane acrop = crop(a, h, w);
+  Plane bcrop = crop(b, h, w);
+  Plane luma = streamLuma(acrop, bcrop); // h x 2w greens
+  Plane quad(2 * w, 2 * h);
+  for (size_t i = 0; i < h; ++i)
+  {
+    for (size_t jx = 0; jx < w; ++jx)
+    {
+      quad.at(2 * i + 1, 2 * jx) = luma.at(i, 2 * jx);     // G (row 2i+1, even)
+      quad.at(2 * i, 2 * jx + 1) = luma.at(i, 2 * jx + 1); // G (row 2i, odd)
+    }
+  }
+  size_t nc = std::min(std::min(c.w, d.w), w);
+  size_t hc = std::min(std::min(h, c.h), d.h);
+  for (size_t i = 0; i < hc; ++i)
+  {
+    for (size_t jx = 0; jx < nc; ++jx)
+    {
+      i64 glo = (luma.at(i, 2 * jx) + luma.at(i, 2 * jx + 1)) >> 1;
+      quad.at(2 * i, 2 * jx) = glo + 2 * c.at(i, jx);         // R
+      quad.at(2 * i + 1, 2 * jx + 1) = glo + 2 * d.at(i, jx); // B
+    }
+  }
+  return quad;
+}
