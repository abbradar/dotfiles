+// SPDX-License-Identifier: LGPL-2.1
+
+//! Bitstream reader for the Sony LLVC v3 (ARW6) entropy coder.
+//!
+//! The entropy stream is MSB-first over bytes (the binary reads "64-bit
+//! big-endian words, MSB-first", which is identical to plain MSB-first over the
+//! byte buffer), so this is a thin shim over the same [`bitstream_io::BitReader`]
+//! in `BigEndian` mode that the Canon CRX decompressor uses.
+//!
+//! End-of-stream is taken straight from `bitstream_io` rather than tracked in a
+//! flag: a fixed-width read past the end zero-fills (`read_bit` -> `Err` -> 0),
+//! and the only unbounded constructs (adaptive-`k` zero-runs) go through
+//! [`Reader::read_zeros`], which is the crate's native unary read and returns
+//! `None` at EOF. Every other decode loop is bounded by the band geometry or by
+//! `k`, so no separate "ended" state is needed.
+
+use std::io::Cursor;
+
+use bitstream_io::BitRead;
+use bitstream_io::BitReader;
+
+type Inner<'a> = BitReader<Cursor<&'a [u8]>, bitstream_io::BigEndian>;
+
+pub(super) struct Reader<'a> {
+  inner: Inner<'a>,
+}
+
+impl<'a> Reader<'a> {
+  /// Create a reader over `buf`, positioned at its first bit.
+  ///
+  /// Callers pass the plane entropy buffer sliced at the band's byte offset, so
+  /// the end of `buf` is the end of the plane data (matching the reference,
+  /// which caps reads at the full plane length and zero-fills beyond it).
+  #[inline]
+  pub(super) fn new(buf: &'a [u8]) -> Self {
+    Self {
+      inner: BitReader::endian(Cursor::new(buf), bitstream_io::BigEndian),
+    }
+  }
+
+  /// Read a single bit MSB-first. Past end of buffer yields `0`.
+  #[inline]
+  pub(super) fn rd1(&mut self) -> u32 {
+    self.inner.read_bit().map(u32::from).unwrap_or(0)
+  }
+
+  /// Read `n` bits MSB-first as an unsigned value.
+  ///
+  /// Implemented bit-by-bit so a buffer underrun zero-fills the remaining bits
+  /// exactly as the reference reader does.
+  #[inline]
+  pub(super) fn rdn(&mut self, n: u32) -> u64 {
+    let mut v: u64 = 0;
+    for _ in 0..n {
+      v = (v << 1) | self.rd1() as u64;
+    }
+    v
+  }
+
+  /// Count the run of `0` bits up to the next `1` bit (consuming the `1`).
+  /// Returns `None` if the stream ends before a `1` bit is found.
+  #[inline]
+  pub(super) fn read_zeros(&mut self) -> Option<i64> {
+    self.inner.read_unary::<1>().ok().map(|z| z as i64)
+  }
+
+  /// Discard bits up to the next whole-byte boundary.
+  #[inline]
+  pub(super) fn align_byte(&mut self) {
+    self.inner.byte_align();
+  }
+}
