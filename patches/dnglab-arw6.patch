-  unimplemented!()
+use header::Geom;
+use reader::Reader;
+
+/// A 2D plane of i64 coefficients/samples (row-major).
+pub(super) struct Plane {
+  pub w: usize,
+  pub h: usize,
+  pub data: Vec<i64>,
+}
+
+impl Plane {
+  #[inline]
+  fn zeros(w: usize, h: usize) -> Self {
+    Self { w, h, data: vec![0; w * h] }
+  }
+
+  #[inline]
+  fn at(&self, r: usize, c: usize) -> i64 {
+    self.data[r * self.w + c]
+  }
+
+  #[inline]
+  fn at_mut(&mut self, r: usize, c: usize) -> &mut i64 {
+    &mut self.data[r * self.w + c]
+  }
+
+  fn clone(&self) -> Self {
+    Self { w: self.w, h: self.h, data: self.data.clone() }
+  }
+}
+
+/// Decode one band into its orientation planes (1 for LL / comp B, 3 for detail).
+///
+/// A single reader runs over the plane entropy buffer from `region_off`,
+/// byte-aligning at the start of each output-row slice; within a slice the
+/// orientations are bit-contiguous. The per-output-row line counts per
+/// orientation are clamped by each orientation's 5/3 row window.
+fn decode_band_contig(buf: &[u8], region_off: usize, width: usize, stride: i64, q_orients: &[i64], geoms: &[Geom], cumsum: bool) -> Vec<Plane> {
+  let groups = width.div_ceil(4);
+  let no = geoms.len();
+  let mut orient_data: Vec<Vec<i64>> = vec![Vec::new(); no];
+  let mut orient_h: Vec<usize> = vec![0; no];
+  let mut out = vec![0i64; 4 * groups];
+  let mut r = Reader::new(&buf[region_off..]);
+  let mut row: i64 = 0;
+  let maxr = geoms.iter().map(|g| (g.bot - g.rowbase) / stride + 3).max().unwrap_or(0);
+  // Bounded by the band's row geometry; end-of-stream just zero-fills.
+  while row < maxr {
+    let ns: Vec<i64> = geoms
+      .iter()
+      .map(|g| 0i64.max(g.bot.min(g.rowbase + row * stride + stride) - g.top.max(g.rowbase + row * stride)))
+      .collect();
+    if ns.iter().sum::<i64>() == 0 {
+      if geoms.iter().all(|g| g.rowbase + row * stride >= g.bot) {
+        break;
+      }
+      row += 1;
+      continue;
+    }
+    r.align_byte();
+    for o in 0..no {
+      for _ in 0..ns[o] {
+        entropy::decode_line_detail(&mut r, groups, q_orients[o], &mut out);
+        let start = orient_data[o].len();
+        orient_data[o].extend_from_slice(&out[..width]);
+        if cumsum {
+          entropy::predict_horizontal(&mut orient_data[o][start..start + width]);
+        }
+        orient_h[o] += 1;
+      }
+    }
+    row += 1;
+  }
+  orient_data
+    .into_iter()
+    .zip(orient_h)
+    .map(|(data, h)| Plane { w: width, h, data })
+    .collect()
+}
+
+/// Reconstruct the four wavelet components `(A, C, D, B)` of one plane.
+fn reconstruct_plane(plane: &[u8], pw: usize, ph: usize) -> Result<(Plane, Plane, Plane, Plane)> {
+  if plane.len() < 0x20 + 5 * 0x20 {
+    return Err(RawlerError::DecoderFailed("ARW6: plane header truncated".into()));
+  }
+  let (totals, recs) = header::parse_header(plane);
+  let j = totals.len() - 1;
+  let geo = header::derive_geom(pw, ph, j);
+  // The band bitstream begins at the RE-derived base (not the old fixed 672);
+  // each band starts with its 16-byte header, giving the entropy offset + q.
+  let buf = &plane[header::bitstream_base(plane)..];
+
+  let mut comps: Vec<Plane> = Vec::with_capacity(3);
+  for comp in 0..3 {
+    // LL band (region 0): single orientation (q from header), horizontal cumsum.
+    let g = &geo.ll;
+    let bo = header::band_offset(&totals, &recs, 0, comp);
+    let (ent, q) = header::band_header(buf, bo)?;
+    let mut img = decode_band_contig(buf, ent, g.width, g.stride, &q, &g.geoms, g.cumsum).remove(0);
+    // Detail levels, coarsest (v=J) -> finest (v=2).
+    for v in (2..=j).rev() {
+      let r = header::detail_region(v, j);
+      if comp >= recs[r].0 {
+        break;
+      }
+      let g = &geo.detail[v];
+      let bo = header::band_offset(&totals, &recs, r, comp);
+      // Entropy offset + per-orientation q come from the band's 16-byte header.
+      let (ent, q) = header::band_header(buf, bo)?;
+      let d = decode_band_contig(buf, ent, g.width, g.stride, &q, &g.geoms, g.cumsum);
+      // Orientation mapping: ll, lh=d[1], hl=d[0], hh=d[2].
+      img = idwt::idwt2d(&img, &d[1], &d[0], &d[2]);
+    }
+    comps.push(img);
+  }
+
+  // comp B (region 4): single full-res highpass band (q from header).
+  let gb = &geo.b;
+  let bo = header::band_offset(&totals, &recs, 4, 0);
+  let (ent, q) = header::band_header(buf, bo)?;
+  let bband = decode_band_contig(buf, ent, gb.width, gb.stride, &q, &gb.geoms, gb.cumsum).remove(0);
+
+  let d = comps.pop().unwrap();
+  let c = comps.pop().unwrap();
+  let a = comps.pop().unwrap();
+  Ok((a, c, d, bband))
+}
+
+/// Wrap to signed 16-bit (matches the binary's i16 intermediate storage).
+#[inline]
+fn i16wrap(v: i64) -> i64 {
+  let v = v & 0xffff;
+  if v >= 0x8000 { v - 0x10000 } else { v }
+}
+
+/// Assemble one quadrant's CFA mosaic (`2H x 2W`, RGGB) from the components.
+///
+/// Luma greens come from the fused A/B combine; chroma R/B are placed on the
+/// Bayer quincunx as `avg(two adjacent greens) + 2 * chroma`.
+fn assemble_quadrant(a: &Plane, c: &Plane, d: &Plane, b: &Plane) -> Plane {
+  let h = a.h.min(b.h);
+  let w = a.w;
+  let acrop = crop(a, h, w);
+  let bcrop = crop(b, h, w);
+  let luma = idwt::stream_luma(&acrop, &bcrop); // h x 2w greens
+  let mut quad = Plane::zeros(2 * w, 2 * h);
+  for i in 0..h {
+    for jx in 0..w {
+      *quad.at_mut(2 * i + 1, 2 * jx) = luma.at(i, 2 * jx); // G (row 2i+1, even col)
+      *quad.at_mut(2 * i, 2 * jx + 1) = luma.at(i, 2 * jx + 1); // G (row 2i, odd col)
+    }
+  }
+  let nc = c.w.min(d.w).min(w);
+  let hc = h.min(c.h).min(d.h);
+  for i in 0..hc {
+    for jx in 0..nc {
+      let glo = (luma.at(i, 2 * jx) + luma.at(i, 2 * jx + 1)) >> 1;
+      *quad.at_mut(2 * i, 2 * jx) = glo + 2 * c.at(i, jx); // R
+      *quad.at_mut(2 * i + 1, 2 * jx + 1) = glo + 2 * d.at(i, jx); // B
+    }
+  }
+  let _ = i16wrap; // (kept for parity with the reference; combine stays in i64 range)
+  quad
+}
+
+fn crop(p: &Plane, h: usize, w: usize) -> Plane {
+  let mut o = Plane::zeros(w, h);
+  for r in 0..h {
+    o.data[r * w..(r + 1) * w].copy_from_slice(&p.data[r * p.w..r * p.w + w]);
+  }
+  o
+}
+
+/// Decompress a Sony LLVC v3 (ARW6) strip into the full CFA mosaic.
+///
+/// * `buf` — the compressed strip (starting at `StripOffsets`).
+/// * `width`/`height` — full sensor mosaic dimensions.
+/// * `comp_bd` — compressed bit depth (selects the linearization curve; 12 supported).
+pub(crate) fn decompress_arw6(buf: &[u8], width: usize, height: usize, comp_bd: usize, dummy: bool) -> Result<PixU16> {
+  if dummy {
+    return Ok(PixU16::new_uninit(width, height));
+  }
+  let curve = match comp_bd {
+    12 => &curve_bd12::DELIN_CURVE_BD12[..],
+    _ => return Err(RawlerError::DecoderFailed(format!("ARW6: unsupported compressed bit depth {comp_bd}"))),
+  };
+  let dc = 1i64 << (comp_bd - 1);
+  let maxv = (1i64 << comp_bd) - 1;
+
+  // The strip header lists the four plane byte offsets.
+  if buf.len() < 8 {
+    return Err(RawlerError::DecoderFailed("ARW6: strip too short".into()));
+  }
+  let u32le = |o: usize| u32::from_le_bytes([buf[o], buf[o + 1], buf[o + 2], buf[o + 3]]) as usize;
+  let count = u32le(0);
+  if count == 0 || count > 16 {
+    return Err(RawlerError::DecoderFailed(format!("ARW6: unexpected plane count {count}")));
+  }
+  let mut offs = Vec::with_capacity(count);
+  for i in 0..count {
+    if 8 + i * 24 + 4 > buf.len() {
+      return Err(RawlerError::DecoderFailed("ARW6: plane offset table truncated".into()));
+    }
+    offs.push(u32le(8 + i * 24));
+  }
+  let planes: Vec<&[u8]> = (0..count)
+    .map(|i| {
+      let end = if i + 1 < count { offs[i + 1] } else { buf.len() };
+      &buf[offs[i].min(buf.len())..end.min(buf.len())]
+    })
+    .collect();
+
+  let pw = width / 2;
+  let ph = height / 2;
+
+  // Each plane reconstructs into a 2H x 2W quadrant; decode in parallel.
+  let quads: Result<Vec<PixU16>> = planes
+    .par_iter()
+    .map(|plane| {
+      let (a, c, d, b) = reconstruct_plane(plane, pw, ph)?;
+      let quad = assemble_quadrant(&a, &c, &d, &b);
+      // Linearize: out = curve[clamp(value + dc, 0, maxv)].
+      let mut out = vec![0u16; quad.w * quad.h];
+      for (o, &v) in out.iter_mut().zip(quad.data.iter()) {
+        let idx = (v + dc).clamp(0, maxv) as usize;
+        *o = curve[idx];
+      }
+      Ok(PixU16::new_with(out, quad.w, quad.h))
+    })
+    .collect();
+  let quads = quads?;
+
+  // Tile the four quadrants: plane0 TL, plane2 TR, plane1 BL, plane3 BR.
+  let qw = pw; // quadrant width  = 2 * (pw/2) = pw
+  let qh = ph; // quadrant height = 2 * (ph/2) = ph
+  if quads.iter().any(|q| q.width != qw || q.height != qh) {
+    let got: Vec<(usize, usize)> = quads.iter().map(|q| (q.width, q.height)).collect();
+    return Err(RawlerError::DecoderFailed(format!("ARW6: quadrant size mismatch, expected {qw}x{qh}, got {got:?}")));
+  }
+  let mut mosaic = PixU16::new(width, height);
+  let order = [(0, 0, 0), (2, 0, qw), (1, qh, 0), (3, qh, qw)]; // (plane, row0, col0)
+  let dst = mosaic.pixels_mut();
+  for &(pi, r0, c0) in order.iter() {
+    if pi >= quads.len() {
+      continue;
+    }
+    let src = quads[pi].pixels();
+    for r in 0..qh {
+      let s = &src[r * qw..(r + 1) * qw];
+      let dstart = (r0 + r) * width + c0;
+      dst[dstart..dstart + qw].copy_from_slice(s);
+    }
+  }
+  Ok(mosaic)
+}
+
+#[cfg(test)]
+mod tests {
+  use super::*;
+
+  /// End-to-end check against the verified Python prototype output.
+  ///
+  /// Set `ARW6_STRIP` to a raw dump of the compressed strip (StripOffsets..),
+  /// `ARW6_REF` to the prototype's `ref_final.bin` (full mosaic, u16 LE), and
+  /// `ARW6_DIM` to `WxH` (e.g. `10016x6672`). Skipped when the env is unset.
+  #[test]
+  fn matches_prototype() {
+    let (strip_path, ref_path, dim) = match (std::env::var("ARW6_STRIP"), std::env::var("ARW6_REF"), std::env::var("ARW6_DIM")) {
+      (Ok(a), Ok(b), Ok(c)) => (a, b, c),
+      _ => {
+        eprintln!("skipping arw6::matches_prototype (ARW6_STRIP/ARW6_REF/ARW6_DIM unset)");
+        return;
+      }
+    };
+    let (w, h) = dim.split_once('x').expect("ARW6_DIM must be WxH");
+    let (width, height): (usize, usize) = (w.parse().unwrap(), h.parse().unwrap());
+
+    let strip = std::fs::read(&strip_path).expect("read strip");
+    let refbytes = std::fs::read(&ref_path).expect("read ref");
+    let reference: Vec<u16> = refbytes.chunks_exact(2).map(|c| u16::from_le_bytes([c[0], c[1]])).collect();
+    assert_eq!(reference.len(), width * height, "reference size");
+
+    let img = decompress_arw6(&strip, width, height, 12, false).expect("decode");
+    let got = img.pixels();
+    assert_eq!(got.len(), reference.len(), "output size");
+
+    let mut diffs = 0usize;
+    let mut maxabs = 0i32;
+    for (i, (&a, &b)) in got.iter().zip(reference.iter()).enumerate() {
+      if a != b {
+        diffs += 1;
+        maxabs = maxabs.max((a as i32 - b as i32).abs());
+        if diffs <= 5 {
+          eprintln!("diff at {i} (row {}, col {}): got {a}, ref {b}", i / width, i % width);
+        }
+      }
+    }
+    let total = reference.len();
+    eprintln!("arw6 vs prototype: {} / {total} exact ({} diffs, max |Δ| {maxabs})", total - diffs, diffs);
+    assert_eq!(diffs, 0, "decoder output must match the verified prototype bit-for-bit");
+  }
 }
