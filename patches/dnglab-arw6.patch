+      if rem == 1 {
+        g += 1;
+        continue;
+      }
+      let e = read_unary_capped(r, rem);
+      let mut run = 1i64 << e;
+      if run < rem {
+        if e > 0 {
+          run += (r.rdn(e as u32) as i64) & ((1i64 << e) - 1);
+        }
+        if run < 0 || rem < run {
+          // Inconsistent zero-run length: only reachable on corrupt input.
+          break;
+        }
+        g += run as usize; // emit `run` zero groups (already 0)
+        // k += 1 + run(0s); stop the line at end-of-stream.
+        match r.read_zeros() {
+          Some(z) => {
+            k += 1 + z;
+            if k >= 0x14 {
+              break;
+            }
+          }
+          None => break,
+        }
+      } else {
+        break;
+      }
+    } else {
+      k = decode_group(r, k, q, g < groups - 1, out, 4 * g);
+      g += 1;
+    }
+  }
+}
+
+/// Horizontal cumulative-sum prediction for the LL band (`FUN_141c85bd0`),
+/// performed with int16 wraparound. `line[0]` is unchanged.
+pub(super) fn predict_horizontal(line: &mut [i64]) {
+  let wrap = |x: i64| -> i64 {
+    let x = x & 0xffff;
+    if x >= 0x8000 { x - 0x10000 } else { x }
+  };
+  let mut acc = wrap(line[0] * 2);
+  for i in 1..line.len() {
+    acc = wrap(line[i] * 2 + acc);
+    line[i] = acc >> 1;
+  }
+}
diff --git a/rawler/src/decompressors/arw6/header.rs b/rawler/src/decompressors/arw6/header.rs
new file mode 100644
index 00000000..36824e5e
--- /dev/null
+++ b/rawler/src/decompressors/arw6/header.rs
@@ -0,0 +1,215 @@
+// SPDX-License-Identifier: LGPL-2.1
+
+//! Plane header parsing and band geometry derivation for Sony LLVC v3 (ARW6).
+//!
+//! Each plane begins with a small header describing five "level totals" and a
+//! per-(level, component) record table (the on-disk form of what the binary
+//! parses into the band descriptors). All band geometry — width, vertical
+//! stride, the 5/3 split heights and the per-orientation row windows — is
+//! derived from the plane dimensions and the level count `J`, matching
+//! `FUN_141c8afc0`/`FUN_141c861d0`. The per-band entropy offset and the
+//! per-orientation quantizers are read from each band's 16-byte header
+//! (`band_header`, `FUN_141c8b310`). Direct port of `arw6_self.parse_header`,
+//! `derive_geom`, `bitstream_base` and `band_header`.
+
+use super::reader::Reader;
+use crate::RawlerError;
+use crate::Result;
+
+/// Row window of one subband orientation: rows `[top, bot)` with phase `rowbase`.
+#[derive(Clone, Copy)]
+pub(super) struct Geom {
+  pub top: i64,
+  pub bot: i64,
+  pub rowbase: i64,
+}
+
+/// Geometry of one band (1 orientation for LL / comp B, 3 for detail levels).
+pub(super) struct BandGeom {
+  pub width: usize,
+  pub stride: i64,
+  pub geoms: Vec<Geom>,
+  pub cumsum: bool,
+}
+
+/// All band geometry for a plane.
+pub(super) struct Geometry {
+  pub ll: BandGeom,
+  pub b: BandGeom,
+  /// Detail bands indexed by vertical level `v`; valid for `v` in `2..=j`.
+  pub detail: Vec<BandGeom>,
+}
+
+#[inline]
+fn u24be(p: &[u8], o: usize) -> i64 {
+  ((p[o] as i64) << 16) | ((p[o + 1] as i64) << 8) | (p[o + 2] as i64)
+}
+
+/// Parse the plane header: the five level totals and the per-level record table.
+/// Returns `(totals, recs)` where each record is `(count, entry_sizes)`.
+pub(super) fn parse_header(plane: &[u8]) -> (Vec<i64>, Vec<(usize, Vec<i64>)>) {
+  let p = &plane[0x10..];
+  let totals: Vec<i64> = [0usize, 3, 6, 9, 12].iter().map(|&o| u24be(p, o) << 4).collect();
+  let mut recs = Vec::with_capacity(5);
+  let mut pos = 0x20usize;
+  for _ in 0..5 {
+    let count = (p[pos] & 0xf) as usize;
+    let off1 = [1usize, 4, 7, 10, 13];
+    let mut ents: Vec<i64> = off1.iter().take(count.min(5)).map(|&o| u24be(p, pos + o) << 4).collect();
+    let mut adv = 0x10usize;
+    if count >= 5 {
+      let off2 = [0x11usize, 0x14, 0x17, 0x1a];
+      ents.extend(off2.iter().take(count - 5).map(|&o| u24be(p, pos + o) << 4));
+      adv = 0x20;
+    }
+    recs.push((count, ents));
+    pos += adv;
+  }
+  (totals, recs)
+}
+
+/// Byte offset (in plane bytes) where the band bitstream begins, i.e. where
+/// `band_offset` 0 (LL comp0's 16-byte header) sits: `0x10` (plane sub-header)
+/// + `0x20` (the level-totals block) + the record-table strides (`0x10` per
+/// record, `0x20` when the count nibble >= 5). Mirrors `FUN_141c87b30`.
+///
+/// (The earlier ports used a fixed `672` = this base + the first LL band's
+/// 544-byte header+table size, which shifted every `band_offset` a constant
+/// 544 bytes past its true header.)
+pub(super) fn bitstream_base(plane: &[u8]) -> usize {
+  let p = &plane[0x10..];
+  let mut pos = 0x20usize;
+  for _ in 0..5 {
+    let count = (p[pos] & 0xf) as usize;
+    pos += if count >= 5 { 0x20 } else { 0x10 };
+  }
+  0x10 + pos
+}
+
+/// Byte offset of band `(region, comp)` within the plane entropy buffer.
+pub(super) fn band_offset(totals: &[i64], recs: &[(usize, Vec<i64>)], region: usize, comp: usize) -> usize {
+  let mut base: i64 = totals[..region].iter().sum();
+  for c in 0..comp {
+    base += recs[region].1[c];
+  }
+  base as usize
+}
+
+/// Header region index for a detail band at vertical level `v`.
+/// (LL is region 0, comp B region 4; detail v=J..=2 map to regions 1..=J-1.)
+pub(super) fn detail_region(v: usize, j: usize) -> usize {
+  j - v + 1
+}
+
+/// Derive all band geometry from the plane dimensions and level count `j`.
+pub(super) fn derive_geom(pw: usize, ph: usize, j: usize) -> Geometry {
+  let pwi = pw as i64;
+  // Vertical 5/3 split sizes per level (lo = coarse ceil, hi = detail floor).
+  let mut split_lo = vec![0i64; j + 1];
+  let mut split_hi = vec![0i64; j + 1];
+  let mut cur = ph as i64;
+  for v in 1..=j {
+    split_lo[v] = (cur + 1) / 2;
+    split_hi[v] = cur / 2;
+    cur = (cur + 1) / 2;
+  }
+  // 5/3 boundary offsets (top) and phases (rowbase), derived recursively.
+  let mut top0 = vec![0i64; j + 1];
+  let mut top1 = vec![0i64; j + 1];
+  top0[1] = 2 * j as i64 + 2;
+  for v in 2..=j {
+    top0[v] = (top0[v - 1] + 1) / 2;
+  }
+  if j >= 2 {
+    top1[2] = top0[1] / 2;
+  }
+  for v in 3..=j {
+    top1[v] = top1[v - 1] / 2;
+  }
+  let rbb = 1i64 << (j as i64 - 2);
+  let rb0 = |v: usize| (1i64).max(rbb >> (v as i64 - 1));
+  let rb1 = |v: usize| rbb >> (v as i64 - 1);
+
+  let empty = || BandGeom {
+    width: 0,
+    stride: 1,
+    geoms: Vec::new(),
+    cumsum: false,
+  };
+  let mut detail: Vec<BandGeom> = (0..=j).map(|_| empty()).collect();
+  let mut b = empty();
+  for v in 1..=j {
+    let w = (pwi >> v) as usize;
+    let st = 1i64 << (j as i64 - v as i64);
+    let lo = split_lo[v];
+    let hi = split_hi[v];
+    if v == 1 {
+      // comp B: single full-res highpass band, no record table.
+      b = BandGeom {
+        width: w,
+        stride: st,
+        geoms: vec![Geom { top: top0[1], bot: top0[1] + hi, rowbase: rb0(1) }],
+        cumsum: false,
+      };
+    } else {
+      detail[v] = BandGeom {
+        width: w,
+        stride: st,
+        cumsum: false,
+        geoms: vec![
+          Geom { top: top0[v], bot: top0[v] + hi, rowbase: rb0(v) },
+          Geom { top: top1[v], bot: top1[v] + lo, rowbase: rb1(v) },
+          Geom { top: top1[v], bot: top1[v] + lo, rowbase: rb1(v) },
+        ],
+      };
+    }
+  }
+  let hi = split_hi[j];
+  let ll = BandGeom {
+    width: (pwi >> j) as usize,
+    stride: 1,
+    cumsum: true,
+    geoms: vec![Geom { top: top0[j], bot: top0[j] + hi, rowbase: rb0(j) }],
+  };
+  Geometry { ll, b, detail }
+}
+
+/// Parse a band's 16-byte header at `buf[off]` (`off` = `band_offset`), the
+/// on-disk structure Adobe parses in `FUN_141c8b310` and validates per band in
+/// `FUN_141c86340` (whose failure aborts the decode). Returns the entropy-slice
+/// offset and the per-orientation quantizers, read MSB-first (the codec's
+/// 64-bit-BE bit order is identical to plain MSB-first over bytes):
+///
+/// ```text
+/// 16b A | 24b sizeB | 4b magic1(=4) | 4b magic2(=0) | 2b mode | 6b _ |
+/// 16b N | 8b (=0x10) | 8b (=0) | 40b _
+/// ```
+///
+/// `size = (A + 1) * 16` is the total header+table byte size (`A` satisfies
+/// `A == ceil((mode + 4) * N / 32)`), so the entropy slices begin at
+/// `off + size`. `mode` is the orientation count (1 for LL & comp B, 3 for
+/// detail = HL/LH/HH); each slice entry is bit-packed `[16b length][mode*4b q]`
+/// and `q` is constant per band, so entry-0's `q` is read. Read order
+/// `q[0]=HL, q[1]=LH, q[2]=HH`. This supersedes the earlier 7-byte-record
+/// prefix/quantizer heuristic.
+pub(super) fn band_header(buf: &[u8], off: usize) -> Result<(usize, Vec<i64>)> {
+  let mut r = Reader::new(&buf[off..]);
+  let a = r.rdn(16);
+  let _size_b = r.rdn(24);
+  let m1 = r.rdn(4);
+  let m2 = r.rdn(4);
+  let mode = r.rdn(2) as usize;
+  r.rdn(6);
+  let n = r.rdn(16);
+  let b9 = r.rdn(8);
+  let b10 = r.rdn(8);
+  r.rdn(40);
+  if !(m1 == 4 && m2 == 0 && b9 == 0x10 && b10 == 0 && a == (((mode as u64 + 4) * n * 4 + 0x7f) >> 7)) {
+    return Err(RawlerError::DecoderFailed(format!(
+      "ARW6: unexpected LLVC band header @{off} (A={a} mode={mode} N={n} magic={m1}/{m2})"
+    )));
+  }
+  r.rdn(16); // entry-0 slice length (unused; entropy is self-delimiting)
+  let q: Vec<i64> = (0..mode).map(|_| r.rdn(4) as i64).collect();
+  Ok((off + (a as usize + 1) * 16, q))
+}
diff --git a/rawler/src/decompressors/arw6/idwt.rs b/rawler/src/decompressors/arw6/idwt.rs
new file mode 100644
index 00000000..90fd5816
--- /dev/null
+++ b/rawler/src/decompressors/arw6/idwt.rs
@@ -0,0 +1,178 @@
+// SPDX-License-Identifier: LGPL-2.1
+
+//! Inverse wavelet transform for Sony LLVC v3 (ARW6).
+//!
+//! The luma component is reconstructed by a separable inverse 5/3 wavelet whose
+//! vertical lifting uses a *flipped polyphase* when the detail-row count is odd
+//! (matching the binary's `FUN_141c8f070`), then combined with the full-res
+//! highpass component via the fused vertical kernel `FUN_141c8a050`
+//! ([`stream_luma`]). Direct port of the verified `arw6_numba` routines.
+
+use super::Plane;
+
+/// Wrap to signed 16-bit (the binary stores intermediate coefficients as i16).
+#[inline]
+fn i16wrap(v: i64) -> i64 {
+  let v = v & 0xffff;
+  if v >= 0x8000 { v - 0x10000 } else { v }
+}
+
+/// Standard inverse 5/3 lifting along axis 0 (rows): coarse at even outputs.
+fn idwt53(low: &Plane, high: &Plane) -> Plane {
+  let w = low.w;
+  let nl = low.h;
+  let nh = high.h;
+  let n = nl + nh;
+  let ne = (n + 1) / 2;
+  let mut x = Plane::zeros(w, n);
+  for nn in 0..nl.min(ne) {
+    for c in 0..w {
+      let dm1 = if nn > 0 && nn <= nh {
+        high.at(nn - 1, c)
+      } else if nh > 0 {
+        high.at(0, c)
+      } else {
+        0
+      };
+      let d0 = if nn < nh {
+        high.at(nn, c)
+      } else if nh > 0 {
+        high.at(nh - 1, c)
+      } else {
+        0
+      };
+      *x.at_mut(2 * nn, c) = low.at(nn, c) - ((dm1 + d0 + 2) >> 2);
+    }
+  }
+  for nn in 0..nh.min(n / 2) {
+    for c in 0..w {
+      let a = x.at(2 * nn, c);
+      let b = if 2 * nn + 2 < n { x.at(2 * nn + 2, c) } else { a };
+      *x.at_mut(2 * nn + 1, c) = high.at(nn, c) + ((a + b) >> 1);
+    }
+  }
+  x
+}
+
+/// Inverse 5/3 with flipped polyphase: detail at even outputs, coarse at odd.
+/// Matches the binary's vertical lift when the detail-row count is odd.
+fn idwt53_flip(low: &Plane, high: &Plane) -> Plane {
+  let w = low.w;
+  let nl = low.h;
+  let nh = high.h;
+  let n = nl + nh;
+  let mut lo = low.clone();
+  let mut hi = high.clone();
+  for nn in 0..nl {
+    for c in 0..w {
+      let h0 = if nn < nh { hi.at(nn, c) } else { hi.at(nh - 1, c) };
+      let h1 = if nn + 1 < nh { hi.at(nn + 1, c) } else { hi.at(nh - 1, c) };
+      *lo.at_mut(nn, c) -= (h0 + h1 + 2) >> 2;
+    }
+  }
+  for nn in 0..nh {
+    for c in 0..w {
+      let l0 = if nn >= 1 { lo.at(nn - 1, c) } else { lo.at(0, c) };
+      let l1 = if nn < nl { lo.at(nn, c) } else { lo.at(nl - 1, c) };
+      *hi.at_mut(nn, c) += (l0 + l1) >> 1;
+    }
+  }
+  let mut x = Plane::zeros(w, n);
+  for nn in 0..nh {
+    if 2 * nn < n {
+      for c in 0..w {
+        *x.at_mut(2 * nn, c) = hi.at(nn, c);
+      }
+    }
+  }
+  for nn in 0..nl {
+    if 2 * nn + 1 < n {
+      for c in 0..w {
+        *x.at_mut(2 * nn + 1, c) = lo.at(nn, c);
+      }
+    }
+  }
+  x
+}
+
+/// Vertical inverse 5/3: phase chosen by the detail-row-count parity (read from
+/// the header geometry, not hardcoded): odd -> flipped polyphase, even -> standard.
+fn vidwt(low: &Plane, high: &Plane) -> Plane {
+  if high.h & 1 == 1 { idwt53_flip(low, high) } else { idwt53(low, high) }
+}
+
+fn transpose(p: &Plane) -> Plane {
+  let mut t = Plane::zeros(p.h, p.w); // new dims: w'=p.h, h'=p.w
+  for r in 0..p.h {
+    for c in 0..p.w {
+      *t.at_mut(c, r) = p.at(r, c);
+    }
+  }
+  t
+}
+
+fn crop(p: &Plane, h: usize, w: usize) -> Plane {
+  let mut o = Plane::zeros(w, h);
+  for r in 0..h {
+    o.data[r * w..(r + 1) * w].copy_from_slice(&p.data[r * p.w..r * p.w + w]);
+  }
+  o
+}
+
+/// One level of 2D inverse 5/3: vertical pass per column-pair, then horizontal.
+/// `lh`/`hl`/`hh` are the three detail orientations.
+pub(super) fn idwt2d(ll: &Plane, lh: &Plane, hl: &Plane, hh: &Plane) -> Plane {
+  let left = vidwt(ll, lh);
+  let right = vidwt(hl, hh);
+  let nr = left.h.min(right.h);
+  let nc = left.w.min(right.w);
+  let lt = transpose(&crop(&left, nr, nc));
+  let rt = transpose(&crop(&right, nr, nc));
+  // Horizontal pass: inverse 5/3 along the (transposed) rows, then transpose back.
+  transpose(&idwt53(&lt, &rt))
+}
+
+/// Fused vertical IDWT + horizontal upsample combining comp A (V-low) and comp B
+/// (V-high) into the luma plane (`H x 2W`). Port of the verified
+/// `FUN_141c8a050` stream (`arw6_numba.stream_luma`). Top boundary reflects
+/// (`line[-1].hi = B[0]`); the final output row reflects the bottom boundary.
+pub(super) fn stream_luma(a: &Plane, b: &Plane) -> Plane {
+  let h = a.h;
+  let w = a.w;
+  let mut lo = Plane::zeros(w, h);
+  let mut hi = Plane::zeros(w, h);
+  let mut luma = Plane::zeros(2 * w, h);
+  for r in 0..h {
+    for n in 0..w {
+      *hi.at_mut(r, n) = b.at(r, n);
+    }
+    for n in 0..w - 1 {
+      let ph0 = if r >= 1 { hi.at(r - 1, n) } else { b.at(r, n) };
+      let ph1 = if r >= 1 { hi.at(r - 1, n + 1) } else { b.at(r, n + 1) };
+      let s = b.at(r, n) + b.at(r, n + 1) + ph0 + ph1;
+      *lo.at_mut(r, n) = i16wrap((2 * a.at(r, n) - (s >> 2)) >> 1);
+    }
+    let phl = if r >= 1 { hi.at(r - 1, w - 1) } else { b.at(r, w - 1) };
+    let s = 2 * (b.at(r, w - 1) + phl);
+    *lo.at_mut(r, w - 1) = i16wrap((2 * a.at(r, w - 1) - (s >> 2)) >> 1);
+  }
+  for r in 1..h {
+    *luma.at_mut(r - 1, 0) = i16wrap((((lo.at(r, 0) + lo.at(r - 1, 0)) * 2) >> 2) + hi.at(r - 1, 0));
+    *luma.at_mut(r - 1, 1) = lo.at(r - 1, 0);
+    for i in 1..w {
+      let ev = i16wrap(((lo.at(r, i - 1) + lo.at(r, i) + lo.at(r - 1, i - 1) + lo.at(r - 1, i)) >> 2) + hi.at(r - 1, i));
+      *luma.at_mut(r - 1, 2 * i) = ev;
+      *luma.at_mut(r - 1, 2 * i + 1) = lo.at(r - 1, i);
+    }
+  }
+  // Last output row: bottom boundary reflects (line[H] = line[H-1] -> rbB = rbA).
+  let r = h - 1;
+  *luma.at_mut(r, 0) = i16wrap(((lo.at(r, 0) * 2) >> 2) + hi.at(r, 0));
+  *luma.at_mut(r, 1) = lo.at(r, 0);
+  for i in 1..w {
+    let ev = i16wrap(((2 * (lo.at(r, i - 1) + lo.at(r, i))) >> 2) + hi.at(r, i));
+    *luma.at_mut(r, 2 * i) = ev;
+    *luma.at_mut(r, 2 * i + 1) = lo.at(r, i);
+  }
+  luma
+}
