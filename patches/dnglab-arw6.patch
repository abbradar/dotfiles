+// SPDX-License-Identifier: LGPL-2.1
+
+//! Sony LLVC v3 (ARW6) entropy decoder.
+//!
+//! Each subband line is coded as a sequence of 4-coefficient groups. A group
+//! stores `k` fixed magnitude bits per coefficient (with an adaptive `k` that
+//! is updated between groups) followed by one sign bit per non-zero
+//! coefficient. Runs of all-zero groups are coded explicitly. This mirrors the
+//! binary's per-line decoder (`FUN_141c853e0`, detail path) and is a direct
+//! port of the verified `arw6_numba.decode_line_detail`.
+
+use super::reader::Reader;
+
+/// Mid-rise dequantizer: `((2*mag+1) << (q-1)) - (mag & 1)`, clamped to i32 max.
+#[inline]
+fn dequant(mag: i64, q: i64) -> i64 {
+  if mag <= 0 || q <= 0 {
+    return mag;
+  }
+  let r = ((2 * mag + 1) << (q - 1)) - (mag & 1);
+  if r > 0x7fff_ffff { 0x7fff_ffff } else { r }
+}
+
+/// Adaptively update the magnitude-bit count `k` (`FUN_141c84b90`).
+fn update_k(r: &mut Reader, k: i64) -> i64 {
+  if r.rd1() == 0 {
+    return k;
+  }
+  if r.rd1() == 0 {
+    // increase: k += 1 + run(0s). EOF before the terminating 1 -> k unchanged.
+    return match r.read_zeros() {
+      Some(z) => k + 1 + z,
+      None => k,
+    };
+  }
+  // decrease: drop k by 1 per 0-bit until a 1-bit, bounded by k reaching 0.
+  if k <= 0 {
+    return 0;
+  }
+  let mut k = k - 1;
+  while k >= 1 {
+    if r.rd1() == 1 {
+      return k;
+    }
+    k -= 1;
+  }
+  k
+}
+
+#[inline]
+fn bit_length(mut x: i64) -> u32 {
+  let mut c = 0;
+  while x > 0 {
+    x >>= 1;
+    c += 1;
+  }
+  c
+}
+
+/// Read a capped unary prefix used for zero-run lengths.
+fn read_unary_capped(r: &mut Reader, remaining: i64) -> i64 {
+  if remaining < 2 {
+    return 0;
+  }
+  let cap = bit_length(remaining - 1) as i64;
+  let mut cnt = 0;
+  while cnt < cap {
+    if r.rd1() == 1 {
+      return cnt;
+    }
+    cnt += 1;
+  }
+  cnt
+}
+
+/// Decode one 4-coefficient group into `out[base..base+4]`; return the new `k`.
+fn decode_group(r: &mut Reader, k: i64, q: i64, not_last: bool, out: &mut [i64], base: usize) -> i64 {
+  let (m0, m1, m2, m3);
+  if k <= 0 {
+    m0 = 0;
+    m1 = 0;
+    m2 = 0;
+    m3 = 0;
+  } else if k < 8 {
+    let v = r.rdn((k * 4) as u32);
+    let m = (1u64 << k) - 1;
+    m0 = ((v >> (3 * k)) & m) as i64;
+    m1 = ((v >> (2 * k)) & m) as i64;
+    m2 = ((v >> k) & m) as i64;
+    m3 = (v & m) as i64;
+  } else {
+    m0 = r.rdn(k as u32) as i64;
+    m1 = r.rdn(k as u32) as i64;
+    m2 = r.rdn(k as u32) as i64;
+    m3 = r.rdn(k as u32) as i64;
+  }
+  let mut v0 = dequant(m0, q);
+  let mut v1 = dequant(m1, q);
+  let mut v2 = dequant(m2, q);
+  let mut v3 = dequant(m3, q);
+  let nz0 = m0 > 0;
+  let nz1 = m1 > 0;
+  let nz2 = m2 > 0;
+  let nz3 = m3 > 0;
+  let new_k = if not_last { update_k(r, k) } else { k };
+  let nsign = nz0 as u32 + nz1 as u32 + nz2 as u32 + nz3 as u32;
+  let sb = if nsign > 0 { r.rdn(nsign) } else { 0 };
+  let mut idx = 0u32;
+  if nz0 {
+    if (sb >> (nsign - 1 - idx)) & 1 == 1 {
+      v0 = -v0;
+    }
+    idx += 1;
+  }
+  if nz1 {
+    if (sb >> (nsign - 1 - idx)) & 1 == 1 {
+      v1 = -v1;
+    }
+    idx += 1;
+  }
+  if nz2 {
+    if (sb >> (nsign - 1 - idx)) & 1 == 1 {
+      v2 = -v2;
+    }
+    idx += 1;
+  }
+  if nz3 {
+    if (sb >> (nsign - 1 - idx)) & 1 == 1 {
+      v3 = -v3;
+    }
+  }
+  out[base] = v0;
+  out[base + 1] = v1;
+  out[base + 2] = v2;
+  out[base + 3] = v3;
+  new_k
+}
